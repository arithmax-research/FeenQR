                    <p style="color: #9ca3af; font-size: 0.875rem; margin: 0.5rem 0 0 0;">Most mentioned stocks on WallStreetBets and r/stocks</p>
                    
                    <button class="search-btn" @onclick="GetTrendingSymbols" disabled="@isLoading" style="margin-top: 1rem; width: 100%;">
                        @(isLoading ? "Loading..." : "Refresh Trending")
                    </button>
