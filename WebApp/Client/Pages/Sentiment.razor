                            <p style="color: #9ca3af; line-height: 1.6; margin-bottom: 1rem;">
                                These symbols are currently trending on financial subreddits. Click any symbol on the left to analyze its sentiment in detail.
                            </p>
                            <div class="trending-list">
                                @foreach (var item in trendingSymbols.Take(10))
                                {
                                    <div class="trending-item" @onclick="() => AnalyzeTrendingSymbol(item.symbol)">
                                        <div class="trending-symbol">$@item.symbol</div>
                                        <div class="trending-mentions">@item.mentions mentions</div>
                                    </div>
