    private void AddAgentLog(string agent, string message)
    {
        agentLogs.Insert(0, new AgentLogEntry
        {
            Agent = agent,
            Message = message,
            Timestamp = DateTime.UtcNow
        });
    }

    public class StrategyPlanResponse
    {
        public string? Type { get; set; }
        public StrategyPlanPayload? Plan { get; set; }
        public StrategyDataPlanPayload? DataPlan { get; set; }
        public StrategyDataAvailabilityPayload? DataAvailability { get; set; }
    }

    public class StrategyPlanPayload
    {
        public string Symbol { get; set; } = string.Empty;
    }

    public class StrategyDataPlanPayload
    {
        public string PreferredSource { get; set; } = string.Empty;
        public string Resolution { get; set; } = string.Empty;
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
    }

    public class StrategyDataAvailabilityPayload
    {
        public bool HasLocalLeanData { get; set; }
        public bool HasRequestedRangeCoverage { get; set; }
        public bool CoverageEstimated { get; set; }
        public DateTime? EarliestAvailableDate { get; set; }
        public DateTime? LatestAvailableDate { get; set; }
        public bool RequiresDownload { get; set; }
    }

    public class StrategyRunResponse
    {
        public string? Type { get; set; }
        public string? RunId { get; set; }
