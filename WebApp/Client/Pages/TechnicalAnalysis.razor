                </div>
            </div>
        }
    </div>
</div>

@code {
    private string activeTab = "analysis";
    private bool isLoading = false;
    private string? errorMessage = null;

    // Input fields
    private string symbol = "AAPL";
    private int lookbackDays = 100;
    private string indicatorCategory = "all";
    private string newSymbol = "";
    private List<string> compareSymbols = new();

    // Pattern-specific fields
    private string patternSymbol = "AAPL";
    private int patternLookbackDays = 365;
    private bool isLoadingAI = false;
    private string aiPatternAnalysis = "";
    private string aiQuestion = "";
    private string aiQuestionResponse = "";

    // Comparison-specific fields
    private int compareLookbackDays = 365;
    private bool isLoadingComparison = false;
    private string comprehensiveComparisonReport = "";
    private string comparisonQuestion = "";
    private string comparisonQuestionResponse = "";

    // Indicator-specific fields
    private string indicatorSymbol = "AAPL";
    private int indicatorLookbackDays = 365;
    private bool isLoadingIndicators = false;
    private string comprehensiveIndicatorAnalysis = "";
    private string indicatorQuestion = "";
    private string indicatorQuestionResponse = "";

