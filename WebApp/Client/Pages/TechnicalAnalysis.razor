    private string GetTradingViewSymbol(string symbol)
    {
        // If symbol already has exchange prefix, return as is
        if (symbol.Contains(':'))
        {
            return symbol;
        }

        // Convert common symbols to TradingView format
        var upperSymbol = symbol.ToUpper();
        
        // Crypto patterns
        if (upperSymbol.EndsWith("USD") || upperSymbol.EndsWith("USDT") || upperSymbol.EndsWith("BTC") || upperSymbol.EndsWith("ETH"))
        {
            return $"BINANCE:{upperSymbol}";
        }
        
        // Common crypto symbols without suffix
        if (upperSymbol == "BTC" || upperSymbol == "ETH" || upperSymbol == "BNB" || upperSymbol == "ADA" || upperSymbol == "SOL")
        {
            return $"BINANCE:{upperSymbol}USDT";
        }

        // Default to NASDAQ for US stocks
        return $"NASDAQ:{upperSymbol}";
    }

