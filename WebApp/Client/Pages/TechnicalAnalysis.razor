        };
    }

    private string FormatAIAnalysis(string text)
    {
        if (string.IsNullOrEmpty(text)) return string.Empty;

        // Remove emojis
        text = System.Text.RegularExpressions.Regex.Replace(text, @"[\u2700-\u27BF]|[\uE000-\uF8FF]|\uD83C[\uDC00-\uDFFF]|\uD83D[\uDC00-\uDFFF]|[\u2011-\u26FF]|\uD83E[\uDD10-\uDDFF]", "");
        
        var lines = text.Split('\n');
        var html = new System.Text.StringBuilder();
        bool inList = false;

        foreach (var line in lines)
        {
            var trimmedLine = line.TrimStart();
            
            // Skip empty lines
            if (string.IsNullOrWhiteSpace(trimmedLine))
            {
                if (inList)
                {
                    html.Append("</ul>");
                    inList = false;
                }
                html.Append("<br/>");
                continue;
            }

            // Handle markdown headers
            if (trimmedLine.StartsWith("### "))
            {
                if (inList) { html.Append("</ul>"); inList = false; }
                var headerText = trimmedLine.Substring(4).Trim();
                html.Append($"<h3>{System.Net.WebUtility.HtmlEncode(headerText)}</h3>");
            }
            else if (trimmedLine.StartsWith("## "))
            {
                if (inList) { html.Append("</ul>"); inList = false; }
                var headerText = trimmedLine.Substring(3).Trim();
                html.Append($"<h3>{System.Net.WebUtility.HtmlEncode(headerText)}</h3>");
            }
            else if (trimmedLine.StartsWith("# "))
            {
                if (inList) { html.Append("</ul>"); inList = false; }
                var headerText = trimmedLine.Substring(2).Trim();
                html.Append($"<h3>{System.Net.WebUtility.HtmlEncode(headerText)}</h3>");
            }
            // Handle numbered lists
            else if (System.Text.RegularExpressions.Regex.IsMatch(trimmedLine, @"^\d+\.\s"))
            {
                if (inList) { html.Append("</ul>"); inList = false; }
                var content = System.Text.RegularExpressions.Regex.Replace(trimmedLine, @"^\d+\.\s", "");
                html.Append($"<h4>{FormatInlineMarkdown(content)}</h4>");
            }
            // Handle bullet points
            else if (trimmedLine.StartsWith("*   ") || trimmedLine.StartsWith("* ") || trimmedLine.StartsWith("- "))
            {
                if (!inList)
                {
                    html.Append("<ul>");
                    inList = true;
                }
                var bulletContent = trimmedLine.TrimStart('*', '-', ' ');
                html.Append($"<li>{FormatInlineMarkdown(bulletContent)}</li>");
            }
            // Regular paragraphs
            else
            {
                if (inList) { html.Append("</ul>"); inList = false; }
                html.Append($"<p>{FormatInlineMarkdown(trimmedLine)}</p>");
            }
        }

        // Close any open list
        if (inList)
        {
            html.Append("</ul>");
        }

        return html.ToString();
    }

    private string FormatInlineMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text)) return string.Empty;

        // Handle bold text with **text**
        text = System.Text.RegularExpressions.Regex.Replace(
            text, 
            @"\*\*([^\*]+)\*\*", 
            "<strong>$1</strong>"
        );

        // Handle code/emphasis with `text`
        text = System.Text.RegularExpressions.Regex.Replace(
            text,
            @"`([^`]+)`",
            "<code style='background: rgba(255,255,255,0.1); padding: 0.2em 0.4em; border-radius: 3px;'>$1</code>"
        );

        return text;
    }

