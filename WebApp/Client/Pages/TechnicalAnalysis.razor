    private string GetSignalClass(string signal)
    {
        return signal.ToLower() switch
        {
            "buy" or "strongbuy" => "signal-buy",
            "sell" or "strongsell" => "signal-sell",
            _ => "signal-neutral"
        };
    }



    private Dictionary<string, object> GetKeyIndicators(Dictionary<string, object>? indicators)
    {
        try
        {
            Console.WriteLine($"GetKeyIndicators called with {indicators?.Count ?? 0} indicators");
            
            if (indicators == null || indicators.Count == 0)
            {
                Console.WriteLine("Indicators is null or empty");
                return new Dictionary<string, object>();
            }
            
            var keyIndicators = new[] { "RSI", "MACD", "MACD_Signal", "SMA_20", "SMA_50", "SMA_200", 
                "ATR", "BB_Upper", "BB_Middle", "BB_Lower", "OBV", "ADX" };
            
            var result = indicators
                .Where(kvp => keyIndicators.Contains(kvp.Key))
                .Take(12)
                .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
            
            Console.WriteLine($"GetKeyIndicators returning {result.Count} indicators");
            return result;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in GetKeyIndicators: {ex.Message}");
            return new Dictionary<string, object>();
        }
    }

    private string FormatIndicatorValue(object value)
    {
        if (value == null) return "N/A";
        
        // System.Text.Json deserializes Dictionary<string, object> values as JsonElement
        if (value is System.Text.Json.JsonElement je)
        {
            return je.ValueKind switch
            {
                System.Text.Json.JsonValueKind.Number => je.TryGetDouble(out var d)
                    ? (d > 1000 ? d.ToString("N0") : d.ToString("F2"))
                    : je.GetRawText(),
                System.Text.Json.JsonValueKind.Array => "[pattern data]",
                System.Text.Json.JsonValueKind.Null => "N/A",
                _ => je.GetRawText()
            };
        }

        if (value is double d2)
            return d2 > 1000 ? d2.ToString("N0") : d2.ToString("F2");

        if (value is decimal dec)
            return dec > 1000 ? dec.ToString("N0") : dec.ToString("F2");
        
        return value.ToString() ?? "N/A";
    }

