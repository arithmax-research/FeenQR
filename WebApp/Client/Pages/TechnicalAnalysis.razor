                                               @bind="aiQuestion" 
                                               @onkeypress="HandleAIQuestionKeyPress" />
                                        <button class="submit-btn" @onclick="AskAIQuestion" disabled="@isLoadingAI">
                                            @(isLoadingAI ? "Asking..." : "Ask AI")
