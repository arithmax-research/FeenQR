@page "/technical-analysis"
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@inject IJSRuntime JS
@inject HttpClient Http

<PageTitle>FeenQR - Technical Analysis</PageTitle>

<style>
    .ta-container {
        position: fixed;
        left: 280px;
        top: 0;
        right: 0;
        bottom: 0;
        background: inherit;
        overflow-x: hidden;
        overflow-y: auto;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
    }

    .ta-header {
        background: rgba(18, 18, 18, 0.95);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding: 1rem 1.5rem;
        position: sticky;
        top: 0;
        z-index: 100;
        flex-shrink: 0;
        width: 100%;
        box-sizing: border-box;
    }

    .tab-navigation {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .tab-btn {
        background: transparent;
        border: none;
        padding: 0.5rem 1rem;
        color: #9ca3af;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        transition: all 0.2s;
    }

    .tab-btn:hover {
        color: #f9fafb;
        background: rgba(255, 255, 255, 0.05);
    }

    .tab-btn.active {
        color: #f9fafb;
        border-bottom-color: #888888;
    }

    .ta-content {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        margin: 0 auto;
        max-width: 1800px;
        width: 100%;
    }

    .two-column-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        height: calc(100vh - 120px);
    }

    .left-column {
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .right-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        overflow-y: auto;
    }

    .widget-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 1.5rem;
    }

    .chart-container {
        flex: 1;
        min-height: 0;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 1.5rem;
    }

    .section-header {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: #ffffff;
    }

    .input-group {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .input-field {
        flex: 1;
        min-width: 200px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #ffffff;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.95rem;
    }

    .input-field:focus {
        outline: none;
        border-color: #1a73e8;
        background: rgba(255, 255, 255, 0.07);
    }

    .select-field {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #ffffff;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.95rem;
        cursor: pointer;
    }

    .submit-btn {
        padding: 0.75rem 2rem;
        background: #1a73e8;
        border: none;
        color: #ffffff;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .submit-btn:hover {
        background: #1557b0;
    }

    .submit-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .results-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .signal-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }

    .signal-buy {
        background: rgba(16, 185, 129, 0.2);
        color: #10b981;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .signal-sell {
        background: rgba(239, 68, 68, 0.2);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .signal-neutral {
        background: rgba(251, 191, 36, 0.2);
        color: #fbbf24;
        border: 1px solid rgba(251, 191, 36, 0.3);
    }

    .indicator-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .indicator-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 1rem;
    }

    .indicator-label {
        color: #9ca3af;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
        font-weight: 500;
    }

    .indicator-value {
        color: #ffffff;
        font-size: 1.25rem;
        font-weight: 700;
    }

    .comparison-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1.5rem;
    }

    .comparison-table th,
    .comparison-table td {
        padding: 1rem;
        text-align: left;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .comparison-table th {
        color: #9ca3af;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .comparison-table td {
        color: #ffffff;
        font-size: 0.95rem;
    }

    .loading-indicator {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        padding: 3rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        margin-bottom: 2rem;
    }

    .spinner {
        width: 50px;
        height: 50px;
        border: 4px solid rgba(255, 255, 255, 0.1);
        border-top: 4px solid #1a73e8;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .progress-text {
        color: #1a73e8;
        font-size: 0.95rem;
        font-weight: 500;
    }

    .reasoning-section {
        background: rgba(26, 115, 232, 0.1);
        border: 1px solid rgba(26, 115, 232, 0.3);
        border-radius: 8px;
        padding: 1.25rem;
        margin-top: 1.5rem;
        color: #e5e7eb;
        line-height: 1.6;
    }

    .pattern-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .pattern-item {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 6px;
        padding: 0.75rem 1rem;
        margin-bottom: 0.5rem;
        color: #e5e7eb;
        font-size: 0.9rem;
    }

    /* Multi-Widget Layout for Patterns */
    .patterns-multi-widget {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .patterns-widget-grid {
        display: grid;
        grid-template-columns: 400px 1fr;
        gap: 1.5rem;
    }

    .patterns-input-widget,
    .patterns-results-widget {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 1.5rem;
    }

    .patterns-input-widget {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .input-label {
        display: block;
        color: #9ca3af;
        font-size: 0.85rem;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    .results-card-compact {
        padding: 0;
    }

    .pattern-details-list-compact {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        max-height: 500px;
        overflow-y: auto;
    }

    .pattern-detail-card-compact {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 1rem;
        transition: all 0.3s ease;
    }

    .pattern-detail-card-compact:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(26, 115, 232, 0.4);
        transform: translateX(4px);
    }

    .pattern-name-compact {
        color: #1a73e8;
        font-size: 0.95rem;
        font-weight: 600;
        margin: 0 0 0.5rem 0;
    }

    .pattern-explanation-compact {
        color: #e5e7eb;
        font-size: 0.85rem;
        line-height: 1.5;
        margin: 0;
    }

    .patterns-ai-widget {
        background: rgba(26, 115, 232, 0.05);
        border: 1px solid rgba(26, 115, 232, 0.2);
        border-radius: 12px;
        padding: 1.5rem;
    }

    .ai-analysis-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 1.5rem;
    }

    .ai-analysis-text {
        color: #e5e7eb;
        line-height: 1.8;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
    }

    .ai-analysis-text h3 {
        color: #ffffff;
        font-size: 1.1rem;
        font-weight: 600;
        margin: 1.5rem 0 1rem 0;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .ai-analysis-text h4 {
        color: #1a73e8;
        font-size: 1rem;
        font-weight: 600;
        margin: 1.25rem 0 0.75rem 0;
    }

    .ai-analysis-text p {
        margin: 0.75rem 0;
        color: #e5e7eb;
    }

    .ai-analysis-text strong {
        color: #ffffff;
        font-weight: 600;
    }

    .ai-analysis-text ul {
        margin: 0.75rem 0;
        padding-left: 1.5rem;
    }

    .ai-analysis-text li {
        margin: 0.5rem 0;
        color: #e5e7eb;
    }

    .ai-analysis-text li strong {
        color: #1a73e8;
    }

    .ai-question-section {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .ai-response-card {
        background: rgba(26, 115, 232, 0.1);
        border: 1px solid rgba(26, 115, 232, 0.3);
        border-radius: 8px;
        padding: 1rem;
        margin-top: 1rem;
    }

    .empty-state {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 300px;
        color: #9ca3af;
        font-style: italic;
        text-align: center;
    }

    @@media (max-width: 1024px) {
        .patterns-widget-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Compare Multi-Widget Layout */
    .compare-multi-widget {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .compare-layout-grid {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 1.5rem;
    }

    .compare-report-widget {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 1.5rem;
        max-height: calc(100vh - 200px);
        overflow-y: auto;
    }

    .compare-controls-widget {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .controls-section {
        display: flex;
        flex-direction: column;
    }

    .submit-btn-compact {
        background: linear-gradient(135deg, #1a73e8 0%, #1557b0 100%);
        border: none;
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .submit-btn-compact:hover:not(:disabled) {
        background: linear-gradient(135deg, #1557b0 0%, #1a73e8 100%);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(26, 115, 232, 0.4);
    }

    .submit-btn-full {
        background: linear-gradient(135deg, #1a73e8 0%, #1557b0 100%);
        border: none;
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        width: 100%;
    }

    .submit-btn-full:hover:not(:disabled) {
        background: linear-gradient(135deg, #1557b0 0%, #1a73e8 100%);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(26, 115, 232, 0.4);
    }

    .submit-btn-full:disabled,
    .submit-btn-compact:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .comparison-report-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 1.5rem;
    }

    .comparison-report-content {
        color: #e5e7eb;
        line-height: 1.8;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
    }

    .comparison-chat-section {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .info-message {
        background: rgba(26, 115, 232, 0.1);
        border: 1px solid rgba(26, 115, 232, 0.3);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        color: #1a73e8;
        font-size: 0.85rem;
        margin-top: 0.75rem;
    }

    .quick-data-section {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .quick-data-table {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .quick-data-row {
        display: grid;
        grid-template-columns: 1fr auto auto;
        align-items: center;
        gap: 0.75rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 6px;
        padding: 0.5rem 0.75rem;
    }

    .quick-data-symbol {
        color: #ffffff;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .quick-data-price {
        color: #9ca3af;
        font-size: 0.85rem;
    }

    .quick-data-signal {
        display: flex;
        justify-content: flex-end;
    }

    .signal-badge-compact {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    @@media (max-width: 1200px) {
        .compare-layout-grid {
            grid-template-columns: 1fr;
        }

        .compare-report-widget {
            max-height: none;
        }
    }

    .pattern-list {
        list-style: none;
        padding: 0;
        margin-top: 1rem;
    }

    .pattern-item {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        border-radius: 6px;
        padding: 0.75rem 1rem;
        margin-bottom: 0.5rem;
        color: #10b981;
        font-weight: 500;
    }

    .pattern-details-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: 1rem;
    }

    .pattern-detail-card {
        background: rgba(30, 41, 59, 0.5);
        border: 1px solid rgba(148, 163, 184, 0.2);
        border-radius: 8px;
        padding: 1rem;
        transition: all 0.2s ease;
    }

    .pattern-detail-card:hover {
        background: rgba(30, 41, 59, 0.7);
        border-color: rgba(148, 163, 184, 0.3);
        transform: translateY(-2px);
    }

    .pattern-name {
        color: #10b981;
        font-size: 1rem;
        font-weight: 600;
        margin: 0 0 0.5rem 0;
    }

    .pattern-explanation {
        color: #cbd5e1;
        font-size: 0.9rem;
        line-height: 1.6;
        margin: 0;
    }

    .multi-symbol-input {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .symbol-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(26, 115, 232, 0.2);
        border: 1px solid rgba(26, 115, 232, 0.3);
        color: #1a73e8;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        margin: 0.25rem;
        font-weight: 500;
    }

    .remove-chip {
        background: none;
        border: none;
        color: #1a73e8;
        cursor: pointer;
        font-size: 1.1rem;
        padding: 0;
        line-height: 1;
    }

    .symbol-chips-container {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .chart-tab {
        position: fixed;
        left: 280px;
        top: 90px;
        right: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        padding: 0;
        margin: 0;
    }

    .tradingview-widget-container {
        position: absolute !important;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        height: 100% !important;
        width: 100% !important;
    }

    .tradingview-widget-container__widget {
        height: 100% !important;
        width: 100% !important;
    }

    /* Indicators Multi-Widget Layout */
    .indicators-multi-widget {
        margin-top: 1rem;
    }

    .indicators-layout-grid {
        display: grid;
        grid-template-columns: 1fr 420px;
        gap: 1.5rem;
        align-items: start;
    }

    .indicators-analysis-widget {
        background: rgba(30, 41, 59, 0.4);
        border: 1px solid rgba(148, 163, 184, 0.15);
        border-radius: 12px;
        padding: 1.5rem;
        min-height: 400px;
    }

    .indicators-controls-widget {
        background: rgba(30, 41, 59, 0.4);
        border: 1px solid rgba(148, 163, 184, 0.15);
        border-radius: 12px;
        padding: 1.5rem;
        position: sticky;
        top: 1rem;
    }

    .indicators-data-card {
        margin-top: 1rem;
    }

    .indicator-header-info {
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(148, 163, 184, 0.15);
    }

    .comprehensive-indicator-report {
        margin-top: 2rem;
        padding: 1.5rem;
        background: rgba(26, 115, 232, 0.05);
        border: 1px solid rgba(26, 115, 232, 0.2);
        border-radius: 8px;
    }

    .indicator-analysis-content {
        color: #e5e7eb;
        line-height: 1.8;
        font-size: 0.95rem;
    }

    .indicators-chat-section {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(148, 163, 184, 0.15);
    }

    .key-indicators-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .key-indicator-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 0.75rem;
        background: rgba(51, 65, 85, 0.3);
        border-radius: 6px;
        transition: background 0.2s ease;
    }

    .key-indicator-row:hover {
        background: rgba(51, 65, 85, 0.5);
    }

    .key-indicator-name {
        color: #94a3b8;
        font-size: 0.8rem;
        font-weight: 500;
    }

    .key-indicator-value {
        color: #ffffff;
        font-size: 0.85rem;
        font-weight: 600;
    }

    @@media (max-width: 1024px) {
        .indicators-layout-grid {
            grid-template-columns: 1fr;
        }

        .indicators-controls-widget {
            position: static;
        }
    }
</style>

<div class="ta-container">
    <div class="ta-header">
        <div class="tab-navigation">
            <button class="tab-btn @(activeTab == "analysis" ? "active" : "")" @onclick='() => SwitchTab("analysis")'>Analysis</button>
            <button class="tab-btn @(activeTab == "indicators" ? "active" : "")" @onclick='() => SwitchTab("indicators")'>Indicators</button>
            <button class="tab-btn @(activeTab == "compare" ? "active" : "")" @onclick='() => SwitchTab("compare")'>Compare</button>
            <button class="tab-btn @(activeTab == "patterns" ? "active" : "")" @onclick='() => SwitchTab("patterns")'>Patterns</button>
            <button class="tab-btn @(activeTab == "long-term" ? "active" : "")" @onclick='() => SwitchTab("long-term")'>Long-Term</button>
            <button class="tab-btn @(activeTab == "chart" ? "active" : "")" @onclick='() => SwitchTab("chart")'>Chart</button>
        </div>
    </div>

    <div class="ta-content">
        @if (activeTab == "analysis")
        {
            <div class="two-column-layout">
                <!-- Left Column: Chart -->
                <div class="left-column">
                    <div class="chart-container">
                        <h3 style="color: #ffffff; margin-bottom: 1rem;">Technical Chart</h3>
                        @if (!string.IsNullOrEmpty(symbol))
                        {
                            <TradingViewTechnicalAnalysisWidget @key="symbol" InitialSymbol="@GetTradingViewSymbol(symbol)" InitialInterval="1D" Title="@($"{symbol} - TradingView Analysis")" />
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #9ca3af;">
                                <p>Enter a symbol to load the chart</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Right Column: Stock Selection & Analysis Results -->
                <div class="right-column">
                    <!-- Stock Selection Widget -->
                    <div class="widget-card">
                        <h3 style="color: #ffffff; margin-bottom: 1rem;">Stock Selection</h3>
                        <div class="input-group" style="margin-bottom: 0;">
                            <input type="text" class="input-field" placeholder="Enter symbol (e.g., AAPL)" @bind="symbol" @onkeypress="HandleKeyPress" />
                            <select class="select-field" @bind="lookbackDays">
                                <option value="30">30 Days</option>
                                <option value="60">60 Days</option>
                                <option value="100" selected>100 Days</option>
                                <option value="200">200 Days</option>
                                <option value="365">1 Year</option>
                            </select>
                        </div>
                        <button class="submit-btn" style="width: 100%; margin-top: 1rem;" @onclick="AnalyzeSymbol" disabled="@isLoading">
                            @(isLoading ? "Analyzing..." : "Analyze")
                        </button>
                    </div>

                    <!-- AI Analysis Widget -->
                    <div class="widget-card" style="flex: 1; overflow-y: auto;">
                        <h3 style="color: #ffffff; margin-bottom: 1rem;">AI Analysis</h3>
                        
                        @if (isLoading)
                        {
                            <div class="loading-indicator">
                                <div class="spinner"></div>
                                <div class="progress-text">Analyzing @symbol... (AI reasoning may take 10-30s)</div>
                            </div>
                        }
                        else if (errorMessage != null)
                        {
                            <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.4); border-radius: 8px; padding: 1.25rem; color: #fca5a5;">
                                <strong>Analysis failed:</strong> @errorMessage
                            </div>
                        }
                        else if (analysisResult != null)
                        {
                            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap;">
                                <h4 style="margin: 0; color: #ffffff; font-size: 1.25rem;">@analysisResult.Symbol</h4>
                                <span style="color: #10b981; font-size: 1.25rem; font-weight: 700;">$@analysisResult.CurrentPrice.ToString("F2")</span>
                            </div>
                            
                            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap;">
                                <span class="signal-badge @GetSignalClass(analysisResult.OverallSignal)" style="font-size: 1rem;">
                                    @analysisResult.OverallSignal
                                </span>
                                <span style="color: #9ca3af;">
                                    Signal Strength: <strong style="color: #ffffff;">@analysisResult.SignalStrength.ToString("F2")</strong>
                                </span>
                            </div>
                            
                            <div style="color: #6b7280; font-size: 0.85rem; margin-bottom: 1rem;">
                                @analysisResult.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC
                            </div>

                            @if (!string.IsNullOrEmpty(analysisResult.Reasoning))
                            {
                                <div style="margin-bottom: 1.5rem;">
                                    <strong style="font-size: 1rem; color: #e5e7eb;">Reasoning:</strong><br /><br />
                                    <div style="line-height: 1.6; font-size: 0.9rem; color: #d1d5db;">
                                        @((MarkupString)analysisResult.Reasoning.Replace("\n", "<br />"))
                                    </div>
                                </div>
                            }

                            @if (analysisResult.Indicators != null && analysisResult.Indicators.Count > 0)
                            {
                                <div style="margin-top: 1.5rem;">
                                    <strong style="color: #e5e7eb; margin-bottom: 0.75rem; display: block;">Key Indicators</strong>
                                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
                                        @foreach (var indicator in GetKeyIndicators(analysisResult.Indicators))
                                        {
                                            <div class="indicator-card">
                                                <div class="indicator-label" style="font-size: 0.75rem;">@FormatIndicatorName(indicator.Key)</div>
                                                <div class="indicator-value" style="font-size: 1rem;">@FormatIndicatorValue(indicator.Value)</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; height: 200px; color: #9ca3af; text-align: center;">
                                <p>Enter a symbol and click "Analyze" to view AI analysis results</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

