@code {
    private string symbol1 = "";
    private string symbol2 = "";
    private string activeTab = "overview";
    private bool isLoading = false;
    private string errorMessage = "";

    private ComprehensiveCointegrationAnalysis? comprehensive;
    private GrangerCausalityTestResult? grangerResult;
    private LeadLagAnalysisResult? leadLagResult;

    private async Task AnalyzePair()
    {
        if (string.IsNullOrWhiteSpace(symbol1) || string.IsNullOrWhiteSpace(symbol2))
        {
            errorMessage = "Please enter both symbols";
            return;
        }

        isLoading = true;
        errorMessage = "";

        try
        {
            await Task.WhenAll(
                FetchComprehensiveAnalysis(),
                FetchGrangerCausality(),
                FetchLeadLag()
            );
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error analyzing pair");
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task FetchComprehensiveAnalysis()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/cointegration/comprehensive-analysis", 
                new { symbol1, symbol2, lookbackDays = 252 });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<ComprehensiveCointegrationAnalysis>>();
                comprehensive = result?.Data;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching comprehensive analysis");
        }
    }

    private async Task FetchGrangerCausality()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/cointegration/granger-causality", 
                new { symbol1, symbol2, lookbackDays = 252, maxLags = 5 });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<GrangerCausalityTestResult>>();
                grangerResult = result?.Data;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching Granger causality");
        }
    }

    private async Task FetchLeadLag()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/cointegration/lead-lag-analysis", 
                new { symbol1, symbol2, lookbackDays = 252 });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<LeadLagAnalysisResult>>();
                leadLagResult = result?.Data;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching lead-lag analysis");
        }
    }

    public class ApiResponse<T>
    {
        public bool Success { get; set; }
        public T? Data { get; set; }
    }

    public class ComprehensiveCointegrationAnalysis
    {
        public string? Symbol1 { get; set; }
        public string? Symbol2 { get; set; }
        public DateTime AnalysisDate { get; set; }
        public EngleGrangerTestResult? EngleGrangerResult { get; set; }
        public decimal CorrelationCoefficient { get; set; }
        public decimal HalfLife { get; set; }
        public decimal SpreadMean { get; set; }
        public decimal SpreadStdDev { get; set; }
        public decimal CurrentSpread { get; set; }
        public decimal SpreadZScore { get; set; }
        public bool IsStationarySpread { get; set; }
        public string? TradingSignal { get; set; }
        public RiskMetricsForPair? RiskMetrics { get; set; }
    }

    public class EngleGrangerTestResult
    {
        public string? Symbol1 { get; set; }
        public string? Symbol2 { get; set; }
        public DateTime TestDate { get; set; }
        public decimal PValue { get; set; }
        public bool IsCointegrated { get; set; }
        public decimal CriticalValue5Pct { get; set; }
        public decimal CriticalValue1Pct { get; set; }
        public decimal BetaCoefficient { get; set; }
        public string? Interpretation { get; set; }
        public string? Recommendation { get; set; }
    }

    public class GrangerCausalityTestResult
    {
        public string? CauseSymbol { get; set; }
        public string? EffectSymbol { get; set; }
        public DateTime TestDate { get; set; }
