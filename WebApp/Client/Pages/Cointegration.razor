@page "/cointegration"
@using System.Text.Json
@using System.Net.Http.Json
@inject HttpClient Http
@inject ILogger<Cointegration> Logger

<div class="page-container">
    <h1>Cointegration & Causality Analysis</h1>
    <p class="subtitle">Analyze relationships between asset pairs using statistical tests</p>

    <!-- Symbol Pair Input -->
    <div class="input-section">
        <div class="input-group">
            <input 
                type="text" 
                placeholder="Symbol 1 (e.g., AAPL)" 
                @bind="symbol1"
                class="symbol-input" />
            <input 
                type="text" 
                placeholder="Symbol 2 (e.g., MSFT)" 
                @bind="symbol2"
                @onkeyup='async e => { if (e.Key == "Enter") await AnalyzePair(); }'
                class="symbol-input" />
            <button class="btn-search" @onclick="AnalyzePair">
                @if (isLoading)
                {
                    <span>⏳ Analyzing...</span>
                }
                else
                {
                    <span>🔬 Analyze</span>
                }
            </button>
        </div>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-box">⚠️ @errorMessage</div>
        }
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <p>🔄 Performing statistical tests...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(symbol1) && !string.IsNullOrEmpty(symbol2) && comprehensive != null)
    {
        <!-- Tabs -->
        <div class="tabs-container">
            <div class="tabs">
                <button class="tab @(activeTab == "overview" ? "active" : "")" 
                        @onclick='() => activeTab = "overview"'>
                    🎯 Overview
                </button>
                <button class="tab @(activeTab == "engle-granger" ? "active" : "")" 
                        @onclick='() => activeTab = "engle-granger"'>
                    📊 Engle-Granger
                </button>
                <button class="tab @(activeTab == "granger" ? "active" : "")" 
                        @onclick='() => activeTab = "granger"'>
                    ➡️ Granger Causality
                </button>
                <button class="tab @(activeTab == "lead-lag" ? "active" : "")" 
                        @onclick='() => activeTab = "lead-lag"'>
                    ⚡ Lead-Lag
                </button>
            </div>

            <!-- Overview Tab -->
            @if (activeTab == "overview")
            {
                <div class="tab-content">
                    <div class="agent-widget">
                        <div class="widget-header">Cointegration Summary: @symbol1 vs @symbol2</div>
                        
                        <div class="metrics-grid">
                            <div class="metric-card">
                                <div class="metric-label">Correlation</div>
                                <div class="metric-value">@comprehensive.CorrelationCoefficient.ToString("F3")</div>
                            </div>
                            <div class="metric-card">
                                <div class="metric-label">Cointegrated</div>
                                <div class="metric-value">@(comprehensive.EngleGrangerResult.IsCointegrated ? "✓ YES" : "✗ NO")</div>
                            </div>
                            <div class="metric-card">
                                <div class="metric-label">Half-Life (days)</div>
                                <div class="metric-value">@comprehensive.HalfLife.ToString("F1")</div>
                            </div>
                            <div class="metric-card">
                                <div class="metric-label">Spread Z-Score</div>
                                <div class="metric-value">@comprehensive.SpreadZScore.ToString("F2")</div>
                            </div>
                        </div>

                        <div class="section">
                            <h3>Trading Signal</h3>
                            <div class="signal-box">
                                <p>@comprehensive.TradingSignal</p>
                            </div>
                        </div>

                        <div class="section">
                            <h3>Spread Statistics</h3>
                            <div class="stats-grid">
                                <div class="stat-item">
                                    <span class="stat-label">Mean Spread</span>
                                    <span class="stat-value">@comprehensive.SpreadMean.ToString("F4")</span>
                                </div>
                                <div class="stat-item">
                                    <span class="stat-label">Std Dev</span>
                                    <span class="stat-value">@comprehensive.SpreadStdDev.ToString("F4")</span>
                                </div>
                                <div class="stat-item">
                                    <span class="stat-label">Current Spread</span>
                                    <span class="stat-value">@comprehensive.CurrentSpread.ToString("F4")</span>
                                </div>
                                <div class="stat-item">
                                    <span class="stat-label">Stationary</span>
                                    <span class="stat-value">@(comprehensive.IsStationarySpread ? "✓ YES" : "✗ NO")</span>
                                </div>
                            </div>
                        </div>

                        <div class="section">
                            <h3>Risk Metrics</h3>
                            <div class="risk-grid">
                                <div class="risk-item">
                                    <span>Max Drawdown</span>
                                    <span class="risk-value">@comprehensive.RiskMetrics.MaxDrawdown.ToString("P1")</span>
                                </div>
                                <div class="risk-item">
                                    <span>Volatility</span>
                                    <span class="risk-value">@comprehensive.RiskMetrics.Volatility.ToString("P1")</span>
                                </div>
                                <div class="risk-item">
                                    <span>Sharpe Ratio</span>
                                    <span class="risk-value">@comprehensive.RiskMetrics.SharpeRatio.ToString("F2")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Engle-Granger Tab -->
            @if (activeTab == "engle-granger" && comprehensive?.EngleGrangerResult != null)
            {
                <div class="tab-content">
                    <div class="agent-widget">
                        <div class="widget-header">Engle-Granger Cointegration Test</div>
                        
                        <div class="test-result">
                            <div class="result-status @(comprehensive.EngleGrangerResult.IsCointegrated ? "pass" : "fail")">
                                @(comprehensive.EngleGrangerResult.IsCointegrated ? "✓ COINTEGRATED" : "✗ NOT COINTEGRATED")
                            </div>
                            <p>@comprehensive.EngleGrangerResult.Interpretation</p>
                        </div>

                        <div class="section">
                            <h3>Test Statistics</h3>
                            <div class="stats-table">
                                <div class="stat-row">
                                    <span>P-Value</span>
                                    <span class="stat-value">@comprehensive.EngleGrangerResult.PValue.ToString("F6")</span>
                                </div>
                                <div class="stat-row">
                                    <span>Critical Value (5%)</span>
                                    <span class="stat-value">@comprehensive.EngleGrangerResult.CriticalValue5Pct.ToString("F4")</span>
                                </div>
                                <div class="stat-row">
                                    <span>Critical Value (1%)</span>
                                    <span class="stat-value">@comprehensive.EngleGrangerResult.CriticalValue1Pct.ToString("F4")</span>
                                </div>
                                <div class="stat-row">
                                    <span>Beta Coefficient</span>
                                    <span class="stat-value">@comprehensive.EngleGrangerResult.BetaCoefficient.ToString("F3")</span>
                                </div>
                            </div>
                        </div>

                        <div class="section">
                            <h3>Trading Recommendation</h3>
                            <p class="recommendation">@comprehensive.EngleGrangerResult.Recommendation</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Granger Causality Tab -->
            @if (activeTab == "granger" && grangerResult != null)
            {
                <div class="tab-content">
                    <div class="agent-widget">
                        <div class="widget-header">Granger Causality Test</div>
                        
                        <div class="causality-result">
                            <div class="causality-direction">
                                <div class="direction-box @(grangerResult.GrangerCauses ? "causes" : "no-cause")">
                                    <div class="direction-label">@grangerResult.CauseSymbol → @grangerResult.EffectSymbol</div>
                                    <div class="direction-status">@(grangerResult.GrangerCauses ? "✓ Granger Causes" : "✗ Does Not Cause")</div>
                                    <div class="direction-pvalue">P-Value: @grangerResult.PValue.ToString("F6")</div>
                                </div>
                            </div>

                            <div class="causality-reverse">
                                <div class="reverse-box @(grangerResult.ReverseGrangerCauses ? "causes" : "no-cause")">
                                    <div class="direction-label">@grangerResult.EffectSymbol → @grangerResult.CauseSymbol</div>
                                    <div class="direction-status">@(grangerResult.ReverseGrangerCauses ? "✓ Reverse Causes" : "✗ No Reverse Cause")</div>
                                    <div class="direction-pvalue">P-Value: @grangerResult.ReverseGrangerPValue.ToString("F6")</div>
                                </div>
                            </div>
                        </div>

                        <div class="section">
                            <h3>Test Details</h3>
                            <div class="stats-table">
                                <div class="stat-row">
                                    <span>Optimal Lags</span>
                                    <span class="stat-value">@grangerResult.OptimalLags</span>
                                </div>
                                <div class="stat-row">
                                    <span>F-Statistic</span>
                                    <span class="stat-value">@grangerResult.GrangerFStatistic.ToString("F4")</span>
                                </div>
                                <div class="stat-row">
                                    <span>Critical Value (5%)</span>
                                    <span class="stat-value">@grangerResult.CriticalValue5Pct.ToString("F4")</span>
                                </div>
                                <div class="stat-row">
                                    <span>Lead Time (Days)</span>
                                    <span class="stat-value">@grangerResult.LeadTime</span>
                                </div>
                            </div>
                        </div>

                        <div class="section">
                            <h3>Interpretation</h3>
                            <p class="interpretation">@grangerResult.Interpretation</p>
                            <p class="recommendation">@grangerResult.Recommendation</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Lead-Lag Tab -->
            @if (activeTab == "lead-lag" && leadLagResult != null)
            {
                <div class="tab-content">
                    <div class="agent-widget">
                        <div class="widget-header">Lead-Lag Analysis</div>
                        
                        <div class="lead-lag-summary">
                            <div class="lead-lag-card">
                                <div class="lead-symbol">Leading: @leadLagResult.LeadingSymbol</div>
                                <div class="lead-time">Lead Time: @leadLagResult.LeadTimeInDays days</div>
                                <div class="max-correlation">Max Correlation: @leadLagResult.MaxCorrelation.ToString("F3")</div>
                            </div>
                        </div>

                        <div class="section">
                            <h3>Lagged Correlations</h3>
                            <div class="correlation-chart">
                                @foreach (var lag in leadLagResult.LaggedCorrelations.OrderBy(x => x.Key))
                                {
                                    <div class="correlation-bar">
                                        <div class="lag-label">@(lag.Key > 0 ? "+" + lag.Key : lag.Key) days</div>
                                        <div class="bar-container">
                                            <div class="bar" style="width: @(Math.Abs(lag.Value) * 100)%; background: @(lag.Value > 0 ? "#00d4ff" : "#ff6464");"></div>
                                        </div>
                                        <div class="correlation-value">@lag.Value.ToString("F3")</div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="section">
                            <h3>Interpretation</h3>
                            <p class="interpretation">@leadLagResult.Interpretation</p>
                            <p class="predictive-value">Predictive Value: @leadLagResult.PredictiveValue</p>
                            <p class="recommendation">Strategy: @leadLagResult.RecommendedTradingStrategy</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
