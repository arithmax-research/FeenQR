    justify-content: space-between;
    background: rgba(0, 212, 255, 0.05);
    padding: 10px;
    border-radius: 4px;
}

.comparison-key {
    color: #999;
}

.comparison-value {
    color: #00d4ff;
    font-weight: bold;
}

.mda-text {
    color: #ccc;
    line-height: 1.8;
}

.loading-indicator {
    text-align: center;
    padding: 40px;
    color: #00d4ff;
    font-size: 1.1em;
}
</style>

@code {
    private string symbolInput = "";
    private string currentSymbol = "";
    private string activeTab = "sec-filings";
    private bool isLoading = false;
    private string errorMessage = "";

    private SecFilingAnalysis secAnalysis = null;
    private List<SecFilingHistory> filingHistory = null;
    private EarningsAnalysis earningsAnalysis = null;
    private List<EarningsHistory> earningsHistory = null;
    private RiskFactorsAnalysis riskFactors = null;
    private MdAAnalysis mdaAnalysis = null;

    private async Task SearchSymbol()
    {
        if (string.IsNullOrWhiteSpace(symbolInput))
        {
            errorMessage = "Please enter a stock symbol";
            return;
        }

        isLoading = true;
        errorMessage = "";
        currentSymbol = symbolInput.ToUpper();

        try
        {
            // Fetch all data in parallel
            await Task.WhenAll(
                FetchSecAnalysis(),
                FetchFilingHistory(),
                FetchEarningsAnalysis(),
                FetchEarningsHistory(),
                FetchRiskFactors(),
                FetchMdA()
            );
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching data for {Symbol}", currentSymbol);
            errorMessage = $"Error loading data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task FetchSecAnalysis()
    {
        try
        {
            var request = new { symbol = currentSymbol, filingType = "10-K" };
            var response = await Http.PostAsJsonAsync("/api/secfilings/analysis", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<SecFilingAnalysis>>();
                secAnalysis = result?.Data;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching SEC analysis");
        }
    }

    private async Task FetchFilingHistory()
    {
        try
        {
            var response = await Http.GetAsync($"/api/secfilings/history/{currentSymbol}?limit=10");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<List<SecFilingHistory>>>();
                filingHistory = result?.Data;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching filing history");
        }
    }

    private async Task FetchEarningsAnalysis()
    {
        try
        {
            var request = new { symbol = currentSymbol };
            var response = await Http.PostAsJsonAsync("/api/secfilings/earnings-analysis", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<EarningsAnalysis>>();
                earningsAnalysis = result?.Data;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching earnings analysis");
        }
    }

    private async Task FetchEarningsHistory()
    {
        try
        {
            var response = await Http.GetAsync($"/api/secfilings/earnings-history/{currentSymbol}?limit=8");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<List<EarningsHistory>>>();
                earningsHistory = result?.Data;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching earnings history");
        }
    }

    private async Task FetchRiskFactors()
    {
        try
        {
            var request = new { symbol = currentSymbol };
            var response = await Http.PostAsJsonAsync("/api/secfilings/risk-factors", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<RiskFactorsAnalysis>>();
                riskFactors = result?.Data;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching risk factors");
        }
    }

    private async Task FetchMdA()
    {
        try
        {
            var request = new { symbol = currentSymbol };
            var response = await Http.PostAsJsonAsync("/api/secfilings/management-discussion", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<MdAAnalysis>>();
                mdaAnalysis = result?.Data;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching MD&A");
        }
    }

    private string FormatMetricValue(object value)
    {
        return value switch
        {
            long l when l > 1000000000 => $"${(l / 1000000000m):F1}B",
            long l when l > 1000000 => $"${(l / 1000000m):F1}M",
            decimal d => $"{d:F2}",
            double d => $"{d:F2}",
            _ => value?.ToString() ?? "N/A"
        };
    }

    private string FormatBillion(decimal value)
    {
        return (value / 1000000000m).ToString("F1");
    }

