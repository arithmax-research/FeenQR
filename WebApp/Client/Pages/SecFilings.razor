}

.tab-content {
    padding: 20px;
    animation: fadeIn 0.3s ease;
}

@@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.agent-widget {
    background: rgba(5, 10, 22, 0.72);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
    backdrop-filter: blur(10px);
}

.widget-header {
    padding-bottom: 15px;
    border-bottom: 2px solid rgba(0, 212, 255, 0.2);
    color: #00d4ff;
    font-size: 1.1em;
    font-weight: bold;
    margin-bottom: 15px;
}

.metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
    margin-bottom: 20px;
}

.metric-card {
    background: rgba(0, 212, 255, 0.05);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 6px;
    padding: 15px;
    text-align: center;
}

.metric-label {
    color: #999;
    font-size: 0.9em;
    margin-bottom: 8px;
}

.metric-value {
    color: #00d4ff;
    font-size: 1.3em;
    font-weight: bold;
}

.section {
    margin-bottom: 20px;
}

.section h3 {
    color: #00d4ff;
    font-size: 1.1em;
