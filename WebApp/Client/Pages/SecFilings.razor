@page "/sec"
@using System.Text.Json
@using System.Net.Http.Json
@inject HttpClient Http
@inject ILogger<SecFilings> Logger

<div class="page-container">
    <h1>SEC Filings & Earnings Analysis</h1>
    <p class="subtitle">Comprehensive SEC filings and earnings call analysis for fundamental research</p>

    <!-- Symbol Input Section -->
    <div class="input-section">
        <div class="input-group">
            <input 
                type="text" 
                placeholder="Enter stock symbol (e.g., AAPL, MSFT)" 
                @bind="symbolInput"
                @onkeyup='async e => { if (e.Key == "Enter") await SearchSymbol(); }'
                class="symbol-input" />
            <button class="btn-search" @onclick="SearchSymbol">
                @if (isLoading)
                {
                    <span>⏳ Loading...</span>
                }
                else
                {
                    <span>🔍 Analyze</span>
                }
            </button>
        </div>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-box">⚠️ @errorMessage</div>
        }
    </div>

    @if (currentSymbol != null && !isLoading)
    {
        <!-- Tabbed Interface -->
        <div class="tabs-container">
            <div class="tabs">
                <button class="tab @(activeTab == "sec-filings" ? "active" : "")" 
                        @onclick='() => activeTab = "sec-filings"'>
                    📄 SEC Filings
                </button>
                <button class="tab @(activeTab == "earnings" ? "active" : "")" 
                        @onclick='() => activeTab = "earnings"'>
                    📊 Earnings
                </button>
                <button class="tab @(activeTab == "risk-factors" ? "active" : "")" 
                        @onclick='() => activeTab = "risk-factors"'>
                    ⚠️ Risk Factors
                </button>
                <button class="tab @(activeTab == "mda" ? "active" : "")" 
                        @onclick='() => activeTab = "mda"'>
                    📋 MD&A
                </button>
                <button class="tab @(activeTab == "comprehensive" ? "active" : "")" 
                        @onclick='() => activeTab = "comprehensive"'>
                    🎯 Comprehensive
                </button>
            </div>

            <!-- SEC Filings Tab -->
            @if (activeTab == "sec-filings")
            {
                <div class="tab-content">
                    @if (secAnalysis != null)
                    {
                        <div class="agent-widget">
                            <div class="widget-header">SEC Filing Analysis for @secAnalysis.Symbol</div>
                            
                            <div class="metrics-grid">
                                <div class="metric-card">
                                    <div class="metric-label">Filing Type</div>
                                    <div class="metric-value">@secAnalysis.FilingType</div>
                                </div>
                                <div class="metric-card">
                                    <div class="metric-label">Filing Date</div>
                                    <div class="metric-value">@secAnalysis.FilingDate.ToString("MMM dd, yyyy")</div>
                                </div>
                                <div class="metric-card">
                                    <div class="metric-label">Company</div>
                                    <div class="metric-value">@secAnalysis.CompanyName</div>
                                </div>
                                <div class="metric-card">
                                    <div class="metric-label">Industry</div>
                                    <div class="metric-value">@secAnalysis.Industry</div>
                                </div>
                            </div>

                            <div class="section">
                                <h3>Executive Summary</h3>
                                <p class="summary-text">@secAnalysis.ExecutiveSummary</p>
                            </div>

                            <div class="section">
                                <h3>Key Metrics</h3>
                                <div class="metrics-highlights">
                                    @foreach (var metric in secAnalysis.KeyMetrics)
                                    {
                                        <div class="highlight-item">
                                            <span class="highlight-key">@metric.Key:</span>
                                            <span class="highlight-value">@FormatMetricValue(metric.Value)</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="section">
                                <h3>Metrics Highlights</h3>
                                <div class="highlights-list">
                                    @foreach (var highlight in secAnalysis.MetricsHighlights)
                                    {
                                        <div class="list-item">✓ @highlight</div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="agent-widget">
                            <div class="widget-header">Filing History</div>
                            @if (filingHistory != null && filingHistory.Count > 0)
                            {
                                <div class="filing-history">
                                    @foreach (var filing in filingHistory)
                                    {
                                        <div class="filing-item">
                                            <div class="filing-type">@filing.FilingType</div>
                                            <div class="filing-date">@filing.FilingDate.ToString("MMM dd, yyyy")</div>
                                            <div class="filing-year">FY @filing.FiscalYear</div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <!-- Earnings Tab -->
            @if (activeTab == "earnings")
            {
                <div class="tab-content">
                    @if (earningsAnalysis != null)
                    {
                        <div class="agent-widget">
                            <div class="widget-header">Latest Earnings - @currentSymbol</div>
                            
                            <div class="earnings-grid">
                                <div class="earnings-card @(earningsAnalysis.EpsBeats ? "beat" : "miss")">
                                    <div class="earnings-label">EPS</div>
                                    <div class="earnings-value">@earningsAnalysis.Eps.ToString("F2")</div>
                                    <div class="earnings-estimate">Est: @earningsAnalysis.EpsEstimate.ToString("F2")</div>
                                    <div class="earnings-status">@(earningsAnalysis.EpsBeats ? "✓ Beat" : "✗ Miss")</div>
                                </div>

                                <div class="earnings-card @(earningsAnalysis.RevenueBeats ? "beat" : "miss")">
                                    <div class="earnings-label">Revenue</div>
                                    <div class="earnings-value">$@FormatBillion(earningsAnalysis.Revenue)B</div>
                                    <div class="earnings-estimate">Est: $@FormatBillion(earningsAnalysis.RevenueEstimate)B</div>
                                    <div class="earnings-status">@(earningsAnalysis.RevenueBeats ? "✓ Beat" : "✗ Miss")</div>
                                </div>

                                <div class="sentiment-card">
                                    <div class="sentiment-label">Sentiment Score</div>
                                    <div class="sentiment-value">@earningsAnalysis.SentimentScore.ToString("F2")</div>
                                    <div class="sentiment-bar">
                                        <div class="sentiment-fill" style="width: @(earningsAnalysis.SentimentScore * 100)%"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="section">
                                <h3>Management Guidance</h3>
                                <p class="guidance-text">@earningsAnalysis.GuidanceFromManagement</p>
                            </div>

                            <div class="section">
                                <h3>Key Takeaways</h3>
                                <div class="takeaways-list">
                                    @foreach (var takeaway in earningsAnalysis.KeyTakeaways)
                                    {
                                        <div class="takeaway-item">📌 @takeaway</div>
                                    }
                                </div>
                            </div>

                            <div class="earnings-date">
                                Latest Earnings: @earningsAnalysis.LatestEarningsDate.ToString("MMMM dd, yyyy")
                            </div>
                        </div>

                        <div class="agent-widget">
                            <div class="widget-header">Earnings History</div>
                            @if (earningsHistory != null && earningsHistory.Count > 0)
                            {
                                <div class="earnings-history-grid">
                                    @foreach (var earnings in earningsHistory)
                                    {
                                        <div class="earnings-history-item">
                                            <div class="history-quarter">@earnings.QuarterYear</div>
                                            <div class="history-eps @(earnings.Beat ? "beat" : "miss")">EPS: @earnings.Eps.ToString("F2")</div>
                                            <div class="history-revenue">Rev: $@FormatBillion(earnings.Revenue)B</div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <!-- Risk Factors Tab -->
            @if (activeTab == "risk-factors")
            {
                <div class="tab-content">
                    @if (riskFactors != null)
                    {
                        <div class="agent-widget">
                            <div class="widget-header">Risk Factors Analysis - @currentSymbol</div>
                            
                            <div class="section">
                                <h3>Risk Summary</h3>
                                <p class="summary-text">@riskFactors.RiskSummary</p>
                            </div>

                            <div class="section">
                                <h3>Identified Risks</h3>
                                <div class="risks-grid">
                                    @foreach (var risk in riskFactors.IdentifiedRisks)
                                    {
                                        <div class="risk-card risk-@risk.Severity.ToLower()">
                                            <div class="risk-category">@risk.Category</div>
                                            <div class="risk-description">@risk.Description</div>
                                            <div class="risk-severity">Severity: @risk.Severity</div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="section">
                                <h3>Mitigation Strategies</h3>
                                <div class="mitigation-list">
                                    @foreach (var strategy in riskFactors.MitigationStrategies)
                                    {
                                        <div class="mitigation-item">→ @strategy</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- MD&A Tab -->
            @if (activeTab == "mda")
            {
                <div class="tab-content">
                    @if (mdaAnalysis != null)
                    {
                        <div class="agent-widget">
                            <div class="widget-header">Management Discussion & Analysis - @currentSymbol</div>
                            
                            <div class="section">
                                <h3>Results of Operations</h3>
                                <p class="mda-text">@mdaAnalysis.ResultsOfOperations</p>
                            </div>

                            <div class="section">
                                <h3>Liquidity and Capital Resources</h3>
                                <p class="mda-text">@mdaAnalysis.LiquidityAndCapitalResources</p>
                            </div>

                            <div class="section">
                                <h3>Operating Activities</h3>
                                <p class="mda-text">@mdaAnalysis.OperatingActivities</p>
                            </div>

                            <div class="section">
                                <h3>Key Metrics Change</h3>
                                <div class="metrics-comparison">
                                    @foreach (var metric in mdaAnalysis.KeyMetricsChange)
                                    {
                                        <div class="comparison-item">
                                            <span class="comparison-key">@metric.Key</span>
                                            <span class="comparison-value">@metric.Value</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Comprehensive Tab -->
            @if (activeTab == "comprehensive")
            {
                <div class="tab-content">
                    <div class="loading-indicator">
                        <span>🔄 Loading comprehensive analysis...</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
.page-container {
    padding: 20px;
    background: linear-gradient(135deg, #0a0e16 0%, #0f1419 100%);
    color: #e0e6ed;
    min-height: 100vh;
}

h1 {
    color: #00d4ff;
    font-size: 2em;
    margin: 0 0 5px 0;
    text-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
}

.subtitle {
    color: #888;
    font-size: 0.95em;
    margin-bottom: 25px;
}

.input-section {
    margin-bottom: 25px;
}

.input-group {
    display: flex;
    gap: 10px;
}

.symbol-input {
    flex: 1;
    padding: 12px 15px;
    background: rgba(20, 25, 35, 0.9);
    border: 2px solid #00d4ff;
    border-radius: 6px;
    color: #00d4ff;
    font-size: 1em;
    outline: none;
