    padding: 10px;
    background: rgba(0, 212, 255, 0.05);
    border-radius: 4px;
    border-left: 3px solid #00d4ff;
}

.highlight-key {
    color: #999;
    font-weight: 500;
}

.highlight-value {
    color: #00d4ff;
    font-weight: bold;
}

.highlights-list, .takeaways-list, .mitigation-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
