}

.earnings-card.beat {
    border-color: #00ff00;
    background: rgba(0, 255, 0, 0.05);
}

.earnings-card.miss {
    border-color: #ff6464;
    background: rgba(255, 100, 100, 0.05);
}

.earnings-label {
    color: #999;
    font-size: 0.9em;
    margin-bottom: 8px;
}

.earnings-value {
    color: #00d4ff;
    font-size: 1.5em;
    font-weight: bold;
    margin-bottom: 5px;
}

.earnings-estimate {
    color: #888;
    font-size: 0.85em;
    margin-bottom: 8px;
}

.earnings-status {
    color: #00ff00;
    font-weight: bold;
    font-size: 0.95em;
}

.earnings-card.miss .earnings-status {
    color: #ff6464;
}

.sentiment-card {
    border-color: #ff9900;
    background: rgba(255, 153, 0, 0.05);
}

.sentiment-label {
    color: #999;
    font-size: 0.9em;
}

.sentiment-value {
    color: #ff9900;
    font-size: 1.8em;
    font-weight: bold;
    margin: 10px 0;
}

.sentiment-bar {
    height: 6px;
    background: rgba(255, 153, 0, 0.1);
    border-radius: 3px;
    overflow: hidden;
    margin-top: 10px;
}

.sentiment-fill {
    height: 100%;
    background: linear-gradient(90deg, #ff9900, #ffaa00);
    transition: width 0.3s ease;
}

.guidance-text {
    color: #ccc;
    line-height: 1.6;
    background: rgba(0, 212, 255, 0.05);
