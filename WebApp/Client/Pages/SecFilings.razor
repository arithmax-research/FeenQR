}

.earnings-date {
    font-size: 0.9em;
    color: #999;
    margin-top: 15px;
    text-align: center;
}

.earnings-history-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 12px;
}

.earnings-history-item {
    background: rgba(0, 212, 255, 0.05);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 6px;
    padding: 12px;
    text-align: center;
}

.history-quarter {
    color: #00d4ff;
    font-weight: bold;
    margin-bottom: 8px;
}

.history-eps, .history-revenue {
    font-size: 0.9em;
    margin: 4px 0;
    color: #ccc;
}

.history-eps.beat {
    color: #00ff00;
}

.history-eps.miss {
    color: #ff6464;
}

.risks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
}

.risk-card {
    background: rgba(255, 100, 100, 0.05);
    border: 2px solid #ff6464;
    border-radius: 6px;
    padding: 15px;
}

.risk-card.risk-high {
    border-color: #ff4444;
    background: rgba(255, 68, 68, 0.08);
}

.risk-card.risk-medium {
    border-color: #ff9900;
    background: rgba(255, 153, 0, 0.06);
}

.risk-card.risk-low {
    border-color: #00d4ff;
    background: rgba(0, 212, 255, 0.05);
}

.risk-category {
    color: #ff9900;
    font-weight: bold;
    margin-bottom: 8px;
}

.risk-description {
    color: #ccc;
    font-size: 0.95em;
    line-height: 1.5;
    margin-bottom: 8px;
}

.risk-severity {
    font-size: 0.85em;
