@page "/stock-pitch"
@using System.Text.Json
@using System.Net.Http.Json
@using FeenQR.Core.Models
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Stock Pitcher</PageTitle>

<div class="container-fluid py-4 stock-pitch-page" id="pitchContainer">
    <!-- Page Header with brand gradient -->
    <div class="pitch-header">
        <div class="pitch-header-content">
            <div class="pitch-header-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            </div>
            <div>
                <h1 class="pitch-title">Stock Pitch Generator</h1>
                <p class="pitch-subtitle">Institutional-quality equity research powered by real-time multi-source data</p>
            </div>
        </div>
        <div class="pitch-header-badge">
            <span class="badge-glow">AI-Powered</span>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Sidebar -->
        <div class="col-lg-3 pitch-sidebar">
            <PitchSidebar @bind-Symbol="Symbol"
                          @bind-Lookback="Lookback"
                          @bind-PositionType="PositionType"
                          OnGenerate="Generate"
                          IsLoading="IsGenerating" />

            <!-- Action buttons -->
            <div class="pitch-actions">
                <button class="pitch-action-btn copy-btn" @onclick="CopyToClipboard" disabled="@(Pitch == null || IsGenerating)">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    <span>@(_copyFeedback ? "Copied!" : "Copy Pitch")</span>
                    @if (_copyFeedback)
                    {
                        <span class="copy-check">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                    }
                </button>
                <button class="pitch-action-btn pdf-btn" @onclick="ExportPdf" disabled="@(Pitch == null || IsGenerating)">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                    </svg>
                    <span>Export PDF</span>
                </button>
                <button class="pitch-action-btn clear-btn" @onclick="ClearPitch" disabled="@(Pitch == null || IsGenerating)">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                    </svg>
                    <span>Clear</span>
                </button>
            </div>

            <!-- Tips -->
            @if (!IsGenerating && Pitch == null && string.IsNullOrEmpty(Error))
            {
                <div class="pitch-tips">
                    <div class="tips-header">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                        <span>Quick Tips</span>
                    </div>
                    <ul class="tips-list">
                        <li>Enter a ticker symbol like <strong>AAPL</strong>, <strong>MSFT</strong>, or <strong>GOOGL</strong></li>
                        <li>Choose position type or let AI decide</li>
                        <li>Adjust lookback period for chart data</li>
                        <li>Covers fundamentals, valuation, news, SEC filings, earnings &amp; technicals</li>
                    </ul>
                </div>
            }
        </div>

        <!-- Right: Main Content Area -->
        <div class="col-lg-9 pitch-main">
            @if (IsGenerating)
            {
                <div class="pitch-loading">
                    <div class="loading-glow"></div>
                    <div class="loading-spinner-ring"></div>
                    <div class="loading-text">Generating Pitch</div>
                    <div class="loading-symbol">@Symbol</div>
                    <div class="loading-status">Gathering data from fundamentals, valuation, news sentiment, SEC filings, earnings, and technical analysis</div>
                    <div class="loading-progress">
                        <div class="progress-bar"></div>
                    </div>
                    <div class="loading-steps">
                        <div class="step active">Research</div>
                        <div class="step">Analysis</div>
                        <div class="step">Pitch</div>
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(Error))
            {
                <div class="pitch-error">
                    <div class="error-icon">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                    </div>
                    <div class="error-title">Generation Failed</div>
                    <div class="error-detail">@Error</div>
                    <button class="pitch-action-btn retry-btn" @onclick="Generate">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                        <span>Try Again</span>
                    </button>
                </div>
            }
            else if (Pitch != null)
            {
                <!-- Tab Navigation -->
                <div class="pitch-tabs">
                    <button class="pitch-tab @(ActiveTab == 0 ? "active" : "")" @onclick="() => SetActiveTab(0)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                        </svg>
                        Pitch Report
                    </button>
                    <button class="pitch-tab @(ActiveTab == 1 ? "active" : "")" @onclick="() => SetActiveTab(1)" disabled="@(ChartData == null)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                        Technical Charts
                        @if (ChartData == null)
                        {
                            <span class="tab-unavailable">N/A</span>
                        }
                    </button>
                    <button class="pitch-tab @(ActiveTab == 2 ? "active" : "")" @onclick="() => SetActiveTab(2)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 13 14 20 7"/><polyline points="4 21 20 21 20 3 4 3 4 21"/></svg>
                        Raw Data
                    </button>
                </div>

                <!-- Tab Content -->
                <div class="pitch-tab-content">
                    @if (ActiveTab == 0)
                    {
                        <PitchContent Pitch="Pitch" />
                    }
                    else if (ActiveTab == 1)
                    {
                        <TechnicalCharts Data="ChartData" />
                    }
                    else if (ActiveTab == 2)
                    {
                        <RawJson Data="Pitch" />
                    }
                </div>
            }
            else
            {
                <!-- Empty state -->
                <div class="pitch-empty">
                    <div class="empty-icon">
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                    </div>
                    <h3>Ready to Generate a Stock Pitch</h3>
                    <p>Enter a stock symbol and configure your preferences, then click <strong>Generate Pitch</strong> to receive an institutional-quality research report.</p>
                    <div class="empty-features">
                        <div class="empty-feature">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
                            <span>Fundamental &amp; Technical Analysis</span>
                        </div>
                        <div class="empty-feature">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15 15 0 0 0 0 20 15 15 0 0 0 0-20z"/><path d="M2 12h20"/></svg>
                            <span>SEC Filings &amp; Earnings Analysis</span>
                        </div>
                        <div class="empty-feature">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            <span>News Sentiment &amp; Market Context</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string Symbol = "AAPL";
    private int Lookback = 365;
    private string PositionType = "auto";
    private bool IsGenerating;
    private StockPitchResult? Pitch;
    private TechnicalChartDto? ChartData;
    private string? Error;
    private int ActiveTab;
    private bool _copyFeedback;

    private async Task Generate()
    {
        if (string.IsNullOrWhiteSpace(Symbol))
        {
            Error = "Please enter a stock symbol.";
            return;
        }

        IsGenerating = true;
        Error = null;
        Pitch = null;
        ChartData = null;
        ActiveTab = 0;

        try
        {
            var cleanSymbol = Symbol.Trim().ToUpper();
            var requestBody = new
            {
                Symbol = cleanSymbol,
                PositionType = PositionType
            };

            var response = await Http.PostAsJsonAsync("/api/stockpitch/generate", requestBody);

            if (!response.IsSuccessStatusCode)
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                Error = $"Server error ({response.StatusCode}): {errorBody}";
                return;
            }

            var responseData = await response.Content.ReadFromJsonAsync<JsonElement>();

            if (responseData.TryGetProperty("success", out var successProp) && successProp.GetBoolean())
            {
                Pitch = new StockPitchResult
                {
                    Symbol = responseData.GetProperty("symbol").GetString() ?? cleanSymbol,
                    PositionType = responseData.GetProperty("positionType").GetString() ?? "N/A",
                    TargetPrice = responseData.GetProperty("targetPrice").GetString() ?? "N/A",
                    ExpectedReturn = responseData.GetProperty("expectedReturn").GetString() ?? "N/A",
                    Conviction = responseData.GetProperty("conviction").GetString() ?? "Medium",
                    TimeHorizon = responseData.GetProperty("timeHorizon").GetString() ?? "6-12 months",
                    GeneratedAt = responseData.GetProperty("generatedAt").GetDateTime().ToString("yyyy-MM-dd HH:mm:ss UTC"),
                    GenerationTimeMs = responseData.GetProperty("generationTimeMs").GetDouble(),
                    DataSources = JsonSerializer.Deserialize<List<string>>(responseData.GetProperty("dataSourcesUsed").GetRawText()) ?? new List<string>()
                };

                var pitch = responseData.GetProperty("pitch");
                if (pitch.TryGetProperty("stockRecommendation", out var rec))
                    Pitch.StockRecommendation = rec.GetString() ?? "";
                if (pitch.TryGetProperty("companyOverview", out var co))
                    Pitch.CompanyOverview = co.GetString() ?? "";
                if (pitch.TryGetProperty("investmentThesis", out var it))
                    Pitch.InvestmentThesis = it.GetString() ?? "";
                if (pitch.TryGetProperty("catalysts", out var cat))
                    Pitch.Catalysts = cat.GetString() ?? "";
                if (pitch.TryGetProperty("valuationAndReturns", out var vr))
                    Pitch.ValuationAndReturns = vr.GetString() ?? "";
                if (pitch.TryGetProperty("risksAndMitigation", out var rm))
                    Pitch.RisksAndMitigation = rm.GetString() ?? "";
                if (pitch.TryGetProperty("conclusion", out var conc))
                    Pitch.Conclusion = conc.GetString() ?? "";

                // Build raw text from sections for clipboard copy
                var rawText = new System.Text.StringBuilder();
                rawText.AppendLine($"STOCK PITCH: {Pitch.Symbol}");
                rawText.AppendLine($"Position: {Pitch.PositionType} | Target: {Pitch.TargetPrice} | Return: {Pitch.ExpectedReturn} | Conviction: {Pitch.Conviction} | Horizon: {Pitch.TimeHorizon}");
                rawText.AppendLine();
                if (!string.IsNullOrWhiteSpace(Pitch.StockRecommendation)) { rawText.AppendLine("STOCK RECOMMENDATION"); rawText.AppendLine(Pitch.StockRecommendation); rawText.AppendLine(); }
                if (!string.IsNullOrWhiteSpace(Pitch.CompanyOverview)) { rawText.AppendLine("COMPANY OVERVIEW"); rawText.AppendLine(Pitch.CompanyOverview); rawText.AppendLine(); }
                if (!string.IsNullOrWhiteSpace(Pitch.InvestmentThesis)) { rawText.AppendLine("INVESTMENT THESIS"); rawText.AppendLine(Pitch.InvestmentThesis); rawText.AppendLine(); }
                if (!string.IsNullOrWhiteSpace(Pitch.Catalysts)) { rawText.AppendLine("CATALYSTS"); rawText.AppendLine(Pitch.Catalysts); rawText.AppendLine(); }
                if (!string.IsNullOrWhiteSpace(Pitch.ValuationAndReturns)) { rawText.AppendLine("VALUATION & RETURNS"); rawText.AppendLine(Pitch.ValuationAndReturns); rawText.AppendLine(); }
                if (!string.IsNullOrWhiteSpace(Pitch.RisksAndMitigation)) { rawText.AppendLine("RISKS & MITIGATION"); rawText.AppendLine(Pitch.RisksAndMitigation); rawText.AppendLine(); }
                if (!string.IsNullOrWhiteSpace(Pitch.Conclusion)) { rawText.AppendLine("CONCLUSION"); rawText.AppendLine(Pitch.Conclusion); }
                Pitch.RawPitchText = rawText.ToString();

                // Fetch technical chart data
                try
                {
                    ChartData = await Http.GetFromJsonAsync<TechnicalChartDto>($"/api/pitch/technicalcharts/{cleanSymbol}?days={Lookback}");
                }
                catch { /* Charts are optional */ }
            }
            else
            {
                if (responseData.TryGetProperty("error", out var errorProp))
                    Error = errorProp.GetString();
                else
                    Error = "Failed to generate stock pitch. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
            Console.WriteLine($"StockPitch error: {ex}");
        }
        finally
        {
            IsGenerating = false;
        }
    }

    private void ClearPitch()
    {
        Pitch = null;
        ChartData = null;
        Error = null;
        ActiveTab = 0;
    }

    private async Task CopyToClipboard()
    {
        if (Pitch != null && !string.IsNullOrEmpty(Pitch.RawPitchText))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Pitch.RawPitchText);
            _copyFeedback = true;
            StateHasChanged();
            await Task.Delay(2000);
            _copyFeedback = false;
            StateHasChanged();
        }
    }

    private async Task ExportPdf()
    {
        await JS.InvokeVoidAsync("feenqr.exportPitchPdf", "pitchContainer", $"{Symbol}-pitch.pdf");
    }

    private void SetActiveTab(int tab)
    {
        ActiveTab = tab;
        if (tab == 1 && ChartData != null)
        {
            _ = Task.Run(async () =>
            {
                await Task.Delay(100);
                await InvokeAsync(StateHasChanged);
            });
        }
    }
}