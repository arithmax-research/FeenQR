            left: 0;
        }
        .sp-content {
            padding: 1rem;
        }
        .summary-banner {
            grid-template-columns: repeat(2, 1fr);
        }
        .input-group {
            flex-direction: column;
        }
    }
</style>

<div class="sp-container">
    <div class="sp-header">
        <h2 style="margin: 0; font-size: 1.25rem; font-weight: 600; color: #fff;">Stock Pitch Generator</h2>
        <p style="margin: 0.25rem 0 0 0; font-size: 0.813rem; color: #6b7280;">
            Generate institutional-quality equity research pitches powered by real-time data
        </p>
    </div>

    <div class="sp-content">
        @* Input Section *@
        <div class="input-section">
            <div class="input-group">
                <div class="input-field">
                    <label for="symbol-input">Stock Symbol</label>
                    <input id="symbol-input" type="text" @bind="symbol" @bind:event="oninput" 
                           placeholder="e.g., AAPL, MSFT, TSLA, NVDA" 
                           @onkeypress="@(async (e) => { if (e.Key == "Enter" && !isLoading) await GeneratePitch(); })" />
                </div>
                <div class="input-field" style="flex: 0.6; min-width: 150px;">
                    <label>Position Type</label>
                    <select @bind="positionType">
                        <option value="auto">Auto (AI Decides)</option>
                        <option value="long">Long / Buy</option>
                        <option value="short">Short / Sell</option>
                    </select>
                </div>
                <button class="btn-primary" @onclick="GeneratePitch" disabled="@isLoading">
                    @(isLoading ? "Generating..." : "Generate Pitch")
                </button>
            </div>
            <div class="help-text">
                Enter a stock symbol to get a comprehensive stock pitch with recommendation, investment thesis, catalysts, valuation analysis, risks, and conclusion.
            </div>
        </div>

        @* Loading State *@
        @if (isLoading)
        {
            <div class="loading-container">
                <div class="loading-spinner"></div>
                <div style="color: #e5e7eb; font-weight: 500;">Generating Stock Pitch for @symbol...</div>
                <div class="loading-status">
                    Gathering data from multiple sources (fundamentals, valuation, news sentiment, SEC filings, earnings, technical analysis)
                </div>
            </div>
        }

        @* Error State *@
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">
                <strong>Error:</strong> @errorMessage
            </div>
        }

        @* Results Section *@
        @if (pitchResult != null)
        {
            <div class="summary-banner">
                <div class="summary-item">
                    <div class="summary-label">Direction</div>
                    <div class="summary-value @pitchResult.PositionType.ToLower()">@pitchResult.PositionType</div>
                </div>
                <div class="summary-item">
                    <div class="summary-label">Target Price</div>
                    <div class="summary-value">@pitchResult.TargetPrice</div>
                </div>
                <div class="summary-item">
                    <div class="summary-label">Expected Return</div>
                    <div class="summary-value @(pitchResult.ExpectedReturn.Contains('-') ? "negative" : "positive")">@pitchResult.ExpectedReturn</div>
                </div>
                <div class="summary-item">
                    <div class="summary-label">Conviction</div>
                    <div class="summary-value">@pitchResult.Conviction</div>
                </div>
                <div class="summary-item">
                    <div class="summary-label">Time Horizon</div>
                    <div class="summary-value" style="font-size: 1.1rem;">@pitchResult.TimeHorizon</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(pitchResult.StockRecommendation))
            {
                <div class="pitch-section">
                    <div class="section-header">
                        <div class="section-icon">📋</div>
                        <div class="section-title">Stock Recommendation</div>
                    </div>
                    <div class="section-content">@pitchResult.StockRecommendation</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(pitchResult.CompanyOverview))
            {
                <div class="pitch-section">
                    <div class="section-header">
                        <div class="section-icon">🏢</div>
                        <div class="section-title">Company Overview</div>
                    </div>
                    <div class="section-content">@pitchResult.CompanyOverview</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(pitchResult.InvestmentThesis))
            {
                <div class="pitch-section">
                    <div class="section-header">
                        <div class="section-icon">💡</div>
                        <div class="section-title">Investment Thesis</div>
                    </div>
                    <div class="section-content">@pitchResult.InvestmentThesis</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(pitchResult.Catalysts))
            {
                <div class="pitch-section">
                    <div class="section-header">
                        <div class="section-icon">⚡</div>
                        <div class="section-title">Catalysts</div>
                    </div>
                    <div class="section-content">@pitchResult.Catalysts</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(pitchResult.ValuationAndReturns))
            {
                <div class="pitch-section">
                    <div class="section-header">
                        <div class="section-icon">💰</div>
                        <div class="section-title">Valuation &amp; Returns</div>
                    </div>
                    <div class="section-content">@pitchResult.ValuationAndReturns</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(pitchResult.RisksAndMitigation))
            {
                <div class="pitch-section">
                    <div class="section-header">
                        <div class="section-icon">⚠️</div>
                        <div class="section-title">Risks &amp; Mitigation</div>
                    </div>
                    <div class="section-content">@pitchResult.RisksAndMitigation</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(pitchResult.Conclusion))
            {
                <div class="pitch-section" style="border-color: rgba(26, 115, 232, 0.3); background: rgba(26, 115, 232, 0.03);">
                    <div class="section-header">
                        <div class="section-icon" style="background: rgba(26, 115, 232, 0.2);">🎯</div>
                        <div class="section-title">Conclusion</div>
                    </div>
                    <div class="section-content">@pitchResult.Conclusion</div>
                </div>
            }

            @* Data Sources *@
            <div class="data-sources-bar">
                <span style="color: #9ca3af; font-size: 0.813rem; font-weight: 500; padding-right: 0.5rem;">Data Sources:</span>
                @if (pitchResult.DataSources != null)
                {
                    @foreach (var source in pitchResult.DataSources)
                    {
                        var isUnavailable = source.Contains("(unavailable)");
                        <span class="data-source-chip @(isUnavailable ? "unavailable" : "")">@source</span>
                    }
                }
            </div>

            <div class="timestamp">
                Generated @pitchResult.GeneratedAt | Analysis time: @pitchResult.GenerationTimeMs.ToString("F0") ms
            </div>
        }
    </div>
</div>

@code {
    private string symbol = "AAPL";
    private string positionType = "auto";
    private bool isLoading = false;
    private string? errorMessage;
    private PitchDisplayResult? pitchResult;

    private async Task GeneratePitch()
    {
        if (string.IsNullOrWhiteSpace(symbol))
        {
            errorMessage = "Please enter a stock symbol.";
            return;
        }

        isLoading = true;
        errorMessage = null;
        pitchResult = null;

        try
        {
            var cleanSymbol = symbol.Trim().ToUpper();
            
            var requestBody = new
            {
                Symbol = cleanSymbol,
                PositionType = positionType
            };

            var response = await Http.PostAsJsonAsync("/api/stockpitch/generate", requestBody);

            if (!response.IsSuccessStatusCode)
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                errorMessage = $"Server error ({response.StatusCode}): {errorBody}";
                return;
            }

            var responseData = await response.Content.ReadFromJsonAsync<JsonElement>();

            if (responseData.TryGetProperty("success", out var successProp) && successProp.GetBoolean())
            {
                pitchResult = new PitchDisplayResult
                {
                    Symbol = responseData.GetProperty("symbol").GetString() ?? cleanSymbol,
                    PositionType = responseData.GetProperty("positionType").GetString() ?? "N/A",
                    TargetPrice = responseData.GetProperty("targetPrice").GetString() ?? "N/A",
                    ExpectedReturn = responseData.GetProperty("expectedReturn").GetString() ?? "N/A",
                    Conviction = responseData.GetProperty("conviction").GetString() ?? "Medium",
                    TimeHorizon = responseData.GetProperty("timeHorizon").GetString() ?? "6-12 months",
                    GeneratedAt = responseData.GetProperty("generatedAt").GetDateTime().ToString("yyyy-MM-dd HH:mm:ss UTC"),
                    GenerationTimeMs = responseData.GetProperty("generationTimeMs").GetDouble(),
                    DataSources = JsonSerializer.Deserialize<List<string>>(responseData.GetProperty("dataSourcesUsed").GetRawText()) ?? new List<string>()
                };

                var pitch = responseData.GetProperty("pitch");
                if (pitch.TryGetProperty("stockRecommendation", out var rec))
                    pitchResult.StockRecommendation = rec.GetString() ?? "";
                if (pitch.TryGetProperty("companyOverview", out var co))
                    pitchResult.CompanyOverview = co.GetString() ?? "";
                if (pitch.TryGetProperty("investmentThesis", out var it))
                    pitchResult.InvestmentThesis = it.GetString() ?? "";
                if (pitch.TryGetProperty("catalysts", out var cat))
                    pitchResult.Catalysts = cat.GetString() ?? "";
                if (pitch.TryGetProperty("valuationAndReturns", out var vr))
                    pitchResult.ValuationAndReturns = vr.GetString() ?? "";
                if (pitch.TryGetProperty("risksAndMitigation", out var rm))
                    pitchResult.RisksAndMitigation = rm.GetString() ?? "";
                if (pitch.TryGetProperty("conclusion", out var conc))
                    pitchResult.Conclusion = conc.GetString() ?? "";
            }
            else
            {
                if (responseData.TryGetProperty("error", out var errorProp))
                    errorMessage = errorProp.GetString();
                else
                    errorMessage = "Failed to generate stock pitch. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            Console.WriteLine($"StockPitch error: {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }

    public class PitchDisplayResult
    {
        public string Symbol { get; set; } = string.Empty;
        public string PositionType { get; set; } = string.Empty;
        public string TargetPrice { get; set; } = "N/A";
        public string ExpectedReturn { get; set; } = "N/A";
        public string Conviction { get; set; } = "Medium";
        public string TimeHorizon { get; set; } = "6-12 months";
        public string GeneratedAt { get; set; } = string.Empty;
        public double GenerationTimeMs { get; set; }
        public List<string> DataSources { get; set; } = new();

        public string StockRecommendation { get; set; } = string.Empty;
        public string CompanyOverview { get; set; } = string.Empty;
        public string InvestmentThesis { get; set; } = string.Empty;
        public string Catalysts { get; set; } = string.Empty;
        public string ValuationAndReturns { get; set; } = string.Empty;
        public string RisksAndMitigation { get; set; } = string.Empty;
        public string Conclusion { get; set; } = string.Empty;
    }
}
