@page "/market-pulse"
@using System.Text.Json
@inject HttpClient Http

<PageTitle>FeenQR - Market Pulse</PageTitle>

<style>
    .pulse-page {
        position: fixed;
        left: 280px;
        top: 0;
        right: 0;
        bottom: 0;
        overflow-y: auto;
        padding: 1rem;
        box-sizing: border-box;
        background: linear-gradient(180deg, rgba(10,12,18,0.98), rgba(15,23,42,0.98));
    }

    .pulse-shell {
        max-width: 1500px;
        margin: 0 auto;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        box-shadow: 0 18px 40px rgba(0,0,0,0.35);
        overflow: hidden;
    }

    .pulse-header {
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        background: linear-gradient(90deg, rgba(37,99,235,0.2), rgba(124,58,237,0.12));
    }

    .pulse-title {
        margin: 0;
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
    }

    .pulse-toolbar {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        display: grid;
        grid-template-columns: 1.1fr 0.9fr 0.55fr 0.55fr;
        gap: 0.9rem;
        align-items: end;
    }

    .field label {
        display: block;
        color: #cbd5e1;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.4rem;
    }

    .field input, .field select {
        width: 100%;
        padding: 0.75rem 0.85rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        color: #f8fafc;
        outline: none;
    }

    .field input::placeholder { color: #64748b; }

    .action-row {
        display: flex;
        gap: 0.5rem;
    }

    .btn-pulse {
        padding: 0.75rem 1rem;
        border-radius: 10px;
        border: 1px solid transparent;
        font-weight: 700;
        cursor: pointer;
        white-space: nowrap;
    }

    .btn-pulse.primary {
        background: #2563eb;
        color: white;
    }

    .btn-pulse.ghost {
        background: transparent;
        border-color: rgba(255,255,255,0.14);
        color: #cbd5e1;
    }

    .pulse-grid {
        display: grid;
        grid-template-columns: 390px 1fr;
        gap: 1rem;
        padding: 1rem 1.25rem 1.25rem;
    }

    .panel {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        overflow: hidden;
        min-height: 640px;
    }

    .panel-header {
        padding: 0.95rem 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        color: #fff;
        font-weight: 700;
    }

    .article-list {
        max-height: 590px;
        overflow: auto;
    }

    .article-item {
        display: block;
        width: 100%;
        text-align: left;
        padding: 0.9rem 1rem;
        color: #e2e8f0;
        background: transparent;
        border: 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        cursor: pointer;
    }

    .article-item:hover, .article-item.active {
        background: rgba(59,130,246,0.15);
    }

    .article-item-title {
        font-weight: 700;
        margin-bottom: 0.3rem;
    }

    .article-item-meta {
        color: #94a3b8;
        font-size: 0.78rem;
    }

    .detail-body {
        padding: 1rem;
        max-height: 590px;
        overflow: auto;
    }

    .content-box {
        white-space: pre-wrap;
        line-height: 1.7;
        color: #e2e8f0;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 1rem;
    }

    .muted { color: #94a3b8; }

    .error { color: #fca5a5; padding: 1rem 1.25rem; }

    .empty-state {
        padding: 2rem 1rem;
        text-align: center;
        color: #94a3b8;
    }

    @@media (max-width: 1100px) {
        .pulse-page { left: 0; }
        .pulse-toolbar { grid-template-columns: 1fr 1fr; }
        .pulse-grid { grid-template-columns: 1fr; }
    }

    @@media (max-width: 640px) {
        .pulse-toolbar { grid-template-columns: 1fr; }
        .pulse-header { flex-direction: column; align-items: flex-start; }
    }
</style>

<div class="pulse-page">
    <section class="pulse-shell">
        <div class="pulse-header">
            <h2 class="pulse-title">Market Pulse</h2>
            <div class="action-row">
                <button class="btn-pulse primary" @onclick="LoadAsync" disabled="@isLoading">@(isLoading ? "Loading..." : "Refresh")</button>
            </div>
        </div>

        <div class="pulse-toolbar">
            <div class="field">
                <label>Symbol</label>
                <input @bind="symbol" @bind:event="oninput" @onkeypress="HandleKeyPress" placeholder="TSLA" />
            </div>
            <div class="field">
                <label>Source Filter</label>
                <select @bind="sourceFilter">
                    <option value="All">All Sources</option>
                    <option value="Reuters">Reuters</option>
                    <option value="Bloomberg">Bloomberg</option>
                    <option value="CNBC">CNBC</option>
                    <option value="MarketWatch">MarketWatch</option>
                    <option value="Yahoo">Yahoo</option>
                </select>
            </div>
            <div class="field">
                <label>Limit</label>
                <input type="number" min="1" max="50" @bind="limit" />
            </div>
            <div class="action-row">
                <button class="btn-pulse ghost" @onclick="ClearAsync" disabled="@(string.IsNullOrWhiteSpace(symbol))">Clear Cache</button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="error">@errorMessage</div>
        }

        <div class="pulse-grid">
            <div class="panel">
                <div class="panel-header">Articles (@articles.Count)</div>
                <div class="article-list">
                    @if (articles.Count == 0)
                    {
                        <div class="empty-state">Search a symbol to load articles from the dual pipeline.</div>
                    }
                    else
                    {
                        @foreach (var article in articles)
                        {
                            <button class="article-item @(selectedArticle?.Url == article.Url ? "active" : string.Empty)" @onclick="() => Select(article)">
                                <div class="article-item-title">@article.Title</div>
                                <div class="article-item-meta">@article.Provider · @article.PublishedDate.ToString("g")</div>
                                <div class="article-item-meta">@article.Source</div>
                            </button>
                        }
                    }
                </div>
            </div>

            <div class="panel">
                <div class="panel-header">Full Source</div>
                <div class="detail-body">
                    @if (selectedArticle is null)
                    {
                        <div class="empty-state">Select a story to populate the full news source here.</div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between gap-2 align-items-start mb-3">
                            <div>
                                <h3 style="color:#fff; margin:0 0 0.35rem;">@selectedArticle.Title</h3>
                                <div class="muted">@selectedArticle.Provider · @selectedArticle.PublishedDate.ToString("f")</div>
                            </div>
                            <a class="btn-pulse ghost" href="@selectedArticle.Url" target="_blank">Open</a>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(selectedArticle.FullContent))
                        {
                            <div class="content-box">@selectedArticle.FullContent</div>
                        }
                        else if (!string.IsNullOrWhiteSpace(selectedArticle.Summary))
                        {
                            <div class="content-box">@selectedArticle.Summary</div>
                        }
                        else
                        {
                            <div class="empty-state">No content was returned for this article.</div>
                        }
                    }
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private string symbol = "TSLA";
    private string sourceFilter = "All";
    private int limit = 20;
    private bool isLoading;
    private string? errorMessage;
    private List<PipelineArticleDto> articles = new();
    private PipelineArticleDto? selectedArticle;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrWhiteSpace(symbol))
        {
            errorMessage = "Enter a symbol first.";
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            var url = $"/api/news/search?ticker={Uri.EscapeDataString(symbol.Trim())}&sourceFilter={Uri.EscapeDataString(sourceFilter)}&limit={limit}";
            var response = await Http.GetAsync(url);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to load market pulse: {response.StatusCode}";
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true, PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
            var result = JsonSerializer.Deserialize<PipelineSearchResultDto>(json, options);
            articles = result?.Articles ?? new List<PipelineArticleDto>();
            selectedArticle = articles.FirstOrDefault();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load market pulse: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void Select(PipelineArticleDto article)
    {
        selectedArticle = article;
    }


    private sealed class PipelineSearchResultDto
    {
        public List<PipelineArticleDto>? Articles { get; set; }
    }

    private sealed class PipelineArticleDto
    {
        public string Title { get; set; } = string.Empty;
        public string Summary { get; set; } = string.Empty;
        public string FullContent { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
        public string Source { get; set; } = string.Empty;
        public string Provider { get; set; } = string.Empty;
        public DateTime PublishedDate { get; set; }
        public bool IsScraped { get; set; }
    }

    private async Task ClearAsync()
    {
        try
        {
            await Http.DeleteAsync($"/api/news/cached/{Uri.EscapeDataString(symbol.Trim())}");
            articles.Clear();
            selectedArticle = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to clear cache: {ex.Message}";
        }
    }
}
