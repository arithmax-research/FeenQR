@* Reusable collapsible section for pitch content *@
<div class="pitch-section @(IsExpanded ? "expanded" : "")">
    <button class="pitch-section-header" @onclick="ToggleSection" aria-expanded="@(IsExpanded ? "true" : "false")">
        <div class="section-title-group">
            <span class="section-indicator"></span>
            <span class="section-title">@Title</span>
        </div>
        <svg class="section-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
        </svg>
    </button>
    <div class="pitch-section-body @(IsExpanded ? "open" : "")">
        <div class="pitch-section-content">
            @Content
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string SectionId { get; set; } = string.Empty;

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Content { get; set; } = string.Empty;

    [Parameter]
    public bool IsExpanded { get; set; }

    private void ToggleSection()
    {
        IsExpanded = !IsExpanded;
    }
}
