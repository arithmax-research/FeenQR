@using FeenQR.Core.Models

@* Renders the structured pitch sections as collapsible accordion cards *@
<div class="pitch-content">
    @if (Pitch != null)
    {
        <!-- Summary Banner -->
        <div class="summary-banner">
            <div class="summary-item">
                <div class="summary-label">Direction</div>
                <div class="summary-value direction @Pitch.PositionType.ToLower()">
                    <span class="direction-dot"></span>
                    @Pitch.PositionType
                </div>
            </div>
            <div class="summary-item">
                <div class="summary-label">Target Price</div>
                <div class="summary-value price">@Pitch.TargetPrice</div>
            </div>
            <div class="summary-item">
                <div class="summary-label">Expected Return</div>
                <div class="summary-value return @(Pitch.ExpectedReturn.StartsWith('-') ? "negative" : "positive")">@Pitch.ExpectedReturn</div>
            </div>
            <div class="summary-item">
                <div class="summary-label">Conviction</div>
                <div class="summary-value conviction">@Pitch.Conviction</div>
            </div>
            <div class="summary-item">
                <div class="summary-label">Time Horizon</div>
                <div class="summary-value horizon">@Pitch.TimeHorizon</div>
            </div>
        </div>

        <!-- Accordion Sections -->
        <div class="pitch-sections">
            @if (!string.IsNullOrWhiteSpace(Pitch.StockRecommendation))
            {
                <RenderSection SectionId="rec" Title="Stock Recommendation" 
                               Content="@Pitch.StockRecommendation" IsExpanded="true" />
            }
            @if (!string.IsNullOrWhiteSpace(Pitch.CompanyOverview))
            {
                <RenderSection SectionId="overview" Title="Company Overview" 
                               Content="@Pitch.CompanyOverview" />
            }
            @if (!string.IsNullOrWhiteSpace(Pitch.InvestmentThesis))
            {
                <RenderSection SectionId="thesis" Title="Investment Thesis" 
                               Content="@Pitch.InvestmentThesis" />
            }
            @if (!string.IsNullOrWhiteSpace(Pitch.Catalysts))
            {
                <RenderSection SectionId="catalysts" Title="Catalysts" 
                               Content="@Pitch.Catalysts" />
            }
            @if (!string.IsNullOrWhiteSpace(Pitch.ValuationAndReturns))
            {
                <RenderSection SectionId="valuation" Title="Valuation and Returns" 
                               Content="@Pitch.ValuationAndReturns" />
            }
            @if (!string.IsNullOrWhiteSpace(Pitch.RisksAndMitigation))
            {
                <RenderSection SectionId="risks" Title="Risks and Mitigation" 
                               Content="@Pitch.RisksAndMitigation" />
            }
            @if (!string.IsNullOrWhiteSpace(Pitch.Conclusion))
            {
                <RenderSection SectionId="conclusion" Title="Conclusion" 
                               Content="@Pitch.Conclusion" />
            }
        </div>

        <!-- Data Sources -->
        <div class="data-sources-bar">
            <span class="data-sources-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15 15 0 0 0 0 20 15 15 0 0 0 0-20z"/><path d="M2 12h20"/></svg>
                Data Sources
            </span>
            <div class="data-source-chips">
                @if (Pitch.DataSources != null)
                {
                    @foreach (var source in Pitch.DataSources)
                    {
                        var isUnavailable = source.Contains("(unavailable)");
                        <span class="data-source-chip @(isUnavailable ? "unavailable" : "")">@source</span>
                    }
                }
            </div>
        </div>

        <div class="pitch-footer">
            <div class="footer-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Generated @Pitch.GeneratedAt
            </div>
            <div class="footer-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Analysis time: @Pitch.GenerationTimeMs.ToString("F0") ms
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public StockPitchResult? Pitch { get; set; }
}

