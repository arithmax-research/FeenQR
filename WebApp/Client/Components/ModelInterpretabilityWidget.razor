@using System.Net.Http.Json
@using Client.Extensions
@using FeenQR.Core.Models
@inject HttpClient HttpClient
@inject NavigationManager Navigation
@inject ILogger<ModelInterpretabilityWidget> Logger

<div class="interpretability-widget">
    <div class="widget-header">
        <h3>🔍 Model Interpretability</h3>
        <div class="widget-controls">
            <input type="text" placeholder="Model name" @bind="modelName" class="widget-input" style="width: 140px;" />
            <button class="widget-iconbutton" @onclick="RefreshAnalysis" disabled="@isLoading" title="Analyze">
                @if (isLoading)
                {
                    <span>⏳</span>
                }
                else
                {
                    <span>🔄</span>
                }
            </button>
        </div>
    </div>

    @if (shapAnalysis != null)
    {
        <div class="widget-content">
            <!-- Top Features Section -->
            <div class="feature-section">
                <div class="section-title">Top Features (SHAP)</div>
                <div class="features-compact">
                    @foreach (var feature in shapAnalysis.FeatureContributions.OrderByDescending(x => Math.Abs(x.Value.ShapValue)).Take(3))
                    {
                        <div class="feature-compact">
                            <span class="feature-badge">@feature.Key</span>
                            <span class="feature-value @(feature.Value.ShapValue > 0 ? "positive" : "negative")">
                                @(feature.Value.ShapValue > 0 ? "+" : "")@feature.Value.ShapValue.ToString("F2")
                            </span>
                        </div>
                    }
                </div>
            </div>

            <!-- Fairness Score -->
            @if (fairnessAnalysis != null)
            {
                <div class="metric-widget-row">
                    <div class="metric-small">
                        <div class="label">Fairness Score</div>
                        <div class="value @(fairnessAnalysis.IsFair ? "fair" : "unfair")">
                            @fairnessAnalysis.FairnessScore.ToString("F0")%
                        </div>
                    </div>
                    <div class="metric-small">
                        <div class="label">Fair?</div>
                        <div class="value @(fairnessAnalysis.IsFair ? "fair" : "unfair")">
                            @(fairnessAnalysis.IsFair ? "✓" : "✗")
                        </div>
                    </div>
                </div>
            }

            <!-- Quick Stats -->
            @if (permutationAnalysis != null)
            {
                <div class="metric-widget-row">
                    <div class="metric-small">
                        <div class="label">Model Accuracy</div>
                        <div class="value">@permutationAnalysis.BaselineAccuracy.ToString("P0")</div>
                    </div>
                    <div class="metric-small">
                        <div class="label">Features</div>
                        <div class="value">@permutationAnalysis.TotalFeatureCount</div>
                    </div>
                </div>
            }

            <!-- Interactions Found -->
            @if (interactionAnalysis != null)
            {
                <div class="metric-widget-row">
                    <div class="metric-small">
                        <div class="label">Interactions Found</div>
                        <div class="value">@interactionAnalysis.FeatureInteractions.Count</div>
                    </div>
                    <div class="metric-small">
                        <div class="label">Avg Strength</div>
                        <div class="value">@interactionAnalysis.AverageInteractionStrength.ToString("F3")</div>
                    </div>
                </div>
            }

            <button class="widget-viewall" @onclick="ViewFullAnalysis">
                View Full Analysis →
            </button>
        </div>
    }
    else if (isLoading)
    {
        <div class="widget-loading">
            <span>⏳ Loading interpretability analysis...</span>
        </div>
    }
    else
    {
        <div class="widget-empty">
            <p>Enter a model name and analyze to see interpretability metrics</p>
        </div>
    }
</div>

@code {
    private string modelName = "RandomForest";
    private bool isLoading = false;

    private ShapAnalysisResult? shapAnalysis = null;
    private ModelFairnessResult? fairnessAnalysis = null;
    private PermutationImportanceResult? permutationAnalysis = null;
    private FeatureInteractionResult? interactionAnalysis = null;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAnalysis();
    }

    private async Task RefreshAnalysis()
    {
        if (string.IsNullOrWhiteSpace(modelName))
            return;

        isLoading = true;

        try
        {
            var tasks = new List<Task>
            {
                FetchShapAnalysis(),
                FetchFairnessAnalysis(),
                FetchPermutationAnalysis(),
                FetchInteractionAnalysis()
            };

            await Task.WhenAll(tasks);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Widget analysis failed");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task FetchShapAnalysis()
    {
        try
        {
            var request = new ShapAnalysisRequest { ModelName = modelName, DatasetSymbol = "AAPL", TopFeatures = 10 };
            shapAnalysis = await HttpClient.PostAsJsonAsync<ShapAnalysisResult>(
                "api/modelinterpretability/shap-analysis", request);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to fetch SHAP");
        }
    }

    private async Task FetchFairnessAnalysis()
    {
        try
        {
            var request = new ModelFairnessRequest { ModelName = modelName, DatasetSymbol = "AAPL", SensitiveAttribute = "demographic" };
            fairnessAnalysis = await HttpClient.PostAsJsonAsync<ModelFairnessResult>(
                "api/modelinterpretability/model-fairness", request);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to fetch fairness");
        }
    }

    private async Task FetchPermutationAnalysis()
    {
        try
        {
            var request = new PermutationImportanceRequest { ModelName = modelName, DatasetSymbol = "AAPL", NumberOfRepeats = 10 };
            permutationAnalysis = await HttpClient.PostAsJsonAsync<PermutationImportanceResult>(
                "api/modelinterpretability/permutation-importance", request);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to fetch permutation");
        }
    }

    private async Task FetchInteractionAnalysis()
    {
        try
        {
            var request = new FeatureInteractionRequest { ModelName = modelName, DatasetSymbol = "AAPL", TopFeaturePairs = 5 };
            interactionAnalysis = await HttpClient.PostAsJsonAsync<FeatureInteractionResult>(
                "api/modelinterpretability/feature-interactions", request);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to fetch interactions");
        }
    }

    private void ViewFullAnalysis()
    {
        Navigation.NavigateTo("/model-interpretability");
    }
}

<style>
