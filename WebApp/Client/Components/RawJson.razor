@using System.Text.Json

@if (Data != null)
{
    <div class="card pitch-card">
        <div class="card-header">
            <h5 class="mb-0">Raw Pitch Data (JSON)</h5>
        </div>
        <div class="card-body">
            <pre class="raw-json-pre"><code>@JsonSerializer.Serialize(Data, new JsonSerializerOptions 
    { 
        WriteIndented = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase 
    })</code></pre>
        </div>
    </div>
}

@code {
    [Parameter]
    public object? Data { get; set; }
}
