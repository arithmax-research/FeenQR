@inject IJSRuntime JS

@if (Data != null)
{
    <div class="chart-panel">
        <div class="chart-panel-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <span>Price Action &amp; Moving Averages</span>
        </div>
        <div class="chart-panel-body">
            <canvas id="priceChart" class="tech-chart-canvas"></canvas>
        </div>
    </div>

    <div class="chart-panel">
        <div class="chart-panel-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <span>RSI &amp; MACD Indicators</span>
        </div>
        <div class="chart-panel-body">
            <canvas id="rsiChart" class="tech-chart-canvas"></canvas>
        </div>
    </div>
}
else
{
    <div class="chart-unavailable">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        <span>Technical chart data is not available for this symbol.</span>
    </div>
}

@code {
    [Parameter]
    public TechnicalChartDto? Data { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Data != null)
        {
            await JS.InvokeVoidAsync("feenqr.renderTechCharts", Data);
        }
    }
}
