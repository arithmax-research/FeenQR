@page "/market-analysis"

<PageTitle>Market Analysis</PageTitle>

<style>
    .analysis-page {
        padding: 24px;
        background: #0f0f0f;
        min-height: 100vh;
    }

    .page-title {
        color: #fff;
        font-size: 28px;
        font-weight: 600;
        margin-bottom: 24px;
    }

    .tabs-container {
        margin-bottom: 24px;
    }

    .nav-tabs {
        border-bottom: 2px solid #333;
    }

    .nav-tabs .nav-link {
        color: #aaa;
        border: none;
        padding: 12px 24px;
        font-weight: 500;
        background: transparent;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
    }

    .nav-tabs .nav-link:hover {
        color: #fff;
        border-color: transparent;
    }

    .nav-tabs .nav-link.active {
        color: #2962ff;
        background: transparent;
        border-color: #2962ff;
    }

    .tab-content {
        background: transparent;
    }

    .analysis-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
    }

    .analysis-grid.two-col {
        grid-template-columns: repeat(2, 1fr);
    }

    @media (max-width: 1200px) {
        .analysis-grid.two-col {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="analysis-page">
    <h1 class="page-title">Market Analysis</h1>

    <!-- Tabs for different analysis types -->
    <div class="tabs-container">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="sentiment-tab" data-bs-toggle="tab" data-bs-target="#sentiment" type="button" role="tab">
                    Sentiment Analysis
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="trading-tab" data-bs-toggle="tab" data-bs-target="#trading" type="button" role="tab">
                    Trading Analysis
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="comprehensive-tab" data-bs-toggle="tab" data-bs-target="#comprehensive" type="button" role="tab">
                    Comprehensive Analysis
                </button>
            </li>
        </ul>
    </div>

    <!-- Tab Content -->
    <div class="tab-content">
        <!-- Sentiment Analysis Tab -->
        <div class="tab-pane fade show active" id="sentiment" role="tabpanel">
            <div class="analysis-grid">
                <MarketPulseWidget />
                <SentimentWidget />
            </div>
        </div>

        <!-- Trading Analysis Tab -->
        <div class="tab-pane fade" id="trading" role="tabpanel">
            <div class="analysis-grid">
                <TradingViewTechnicalAnalysisWidget InitialSymbol="BINANCE:BTCUSDT" InitialInterval="1D" />
            </div>
        </div>

        <!-- Comprehensive Analysis Tab -->
        <div class="tab-pane fade" id="comprehensive" role="tabpanel">
            <div class="analysis-grid two-col">
                <TechnicalAnalysisWidget />
                <ComprehensiveAnalysisWidget />
            </div>
        </div>
    </div>
</div>
