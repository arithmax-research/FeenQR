@using System.Text.Json

<div class="card shadow-sm mb-4">
    <div class="card-header bg-gradient text-white" style="background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 55%, #7c3aed 100%);">
        <h5 class="card-title mb-0">
            <i class="bi bi-newspaper me-2"></i>Dual News Pipeline
        </h5>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end mb-3">
            <div class="col-lg-3 col-md-4">
                <label class="form-label fw-semibold">Symbol</label>
                <input class="form-control" @bind="symbol" @bind:event="oninput" placeholder="TSLA" @onkeypress="HandleKeyPress" />
            </div>
            <div class="col-lg-3 col-md-4">
                <label class="form-label fw-semibold">Source</label>
                <select class="form-select" @bind="sourceFilter">
                    <option value="All">All Sources</option>
                    <option value="Reuters">Reuters</option>
                    <option value="Bloomberg">Bloomberg</option>
                    <option value="CNBC">CNBC</option>
                    <option value="MarketWatch">MarketWatch</option>
                    <option value="Yahoo">Yahoo</option>
                </select>
            </div>
            <div class="col-lg-2 col-md-4">
                <label class="form-label fw-semibold">Limit</label>
                <input class="form-control" type="number" min="1" max="50" @bind="limit" />
            </div>
            <div class="col-lg-2 col-md-6 d-grid">
                <button class="btn btn-primary" @onclick="SearchAsync" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Loading</span>
                    }
                    else
                    {
                        <span><i class="bi bi-search me-2"></i>Search</span>
                    }
                </button>
            </div>
            <div class="col-lg-2 col-md-6 d-grid">
                <button class="btn btn-outline-secondary" @onclick="ClearAsync" disabled="@(string.IsNullOrWhiteSpace(symbol))">
                    <i class="bi bi-trash me-2"></i>Clear Cache
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
            </div>
        }

        @if (articles.Count > 0)
        {
            <div class="row g-3">
                <div class="col-lg-5">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="fw-semibold"><i class="bi bi-list-ul me-2"></i>Articles (@articles.Count)</span>
                            <small class="text-muted">Click one to load full content</small>
                        </div>
                        <div class="list-group list-group-flush" style="max-height: 620px; overflow:auto;">
                            @foreach (var article in articles)
                            {
                                <button class="list-group-item list-group-item-action @(selectedArticle?.Url == article.Url ? "active" : "")" @onclick="() => SelectArticle(article)">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div class="text-start flex-grow-1">
                                            <div class="fw-semibold">@article.Title</div>
                                            <div class="small @(selectedArticle?.Url == article.Url ? "text-white-50" : "text-muted")">@article.Provider · @article.PublishedDate.ToString("g")</div>
                                            <div class="small @(selectedArticle?.Url == article.Url ? "text-white-50" : "text-muted")">@article.Source</div>
                                        </div>
                                        @if (article.IsScraped)
                                        {
                                            <span class="badge bg-success align-self-start">Full</span>
                                        }
                                    </div>
                                </button>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="fw-semibold"><i class="bi bi-file-text me-2"></i>Full Source</span>
                            @if (selectedArticle != null)
                            {
                                <a class="btn btn-sm btn-outline-primary" href="@selectedArticle.Url" target="_blank"><i class="bi bi-box-arrow-up-right me-1"></i>Open</a>
                            }
                        </div>
                        <div class="card-body" style="max-height: 620px; overflow:auto;">
                            @if (selectedArticle == null)
                            {
                                <div class="text-center text-muted py-5">
                                    <i class="bi bi-arrow-left-circle display-6"></i>
                                    <div class="mt-3">Select a story to populate the full news source here.</div>
                                </div>
                            }
                            else
                            {
                                <h5 class="mb-2">@selectedArticle.Title</h5>
                                <div class="text-muted small mb-3">@selectedArticle.Provider · @selectedArticle.PublishedDate.ToString("f")</div>
                                @if (!string.IsNullOrWhiteSpace(selectedArticle.FullContent))
                                {
                                    <div class="alert alert-success py-2 px-3">
                                        <i class="bi bi-check-circle me-1"></i>Full content cached from the pipeline
                                    </div>
                                    <div class="pipeline-content">@selectedArticle.FullContent</div>
                                }
                                else if (!string.IsNullOrWhiteSpace(selectedArticle.Summary))
                                {
                                    <p class="mb-0">@selectedArticle.Summary</p>
                                }
                                else
                                {
                                    <div class="alert alert-warning mb-0">No content was returned for this article.</div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (!isLoading && string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-info mb-0">
                <i class="bi bi-info-circle me-2"></i>Enter a symbol and search to load articles from NewsAPI + yfinance.
            </div>
        }
    </div>
</div>

@code {
    private string symbol = "TSLA";
    private string sourceFilter = "All";
    private int limit = 20;
    private bool isLoading;
    private string? errorMessage;
    private List<QuantResearchAgent.Models.PipelineArticle> articles = new();
    private QuantResearchAgent.Models.PipelineArticle? selectedArticle;

    [Inject]
    private HttpClient Http { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await SearchAsync();
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchAsync();
        }
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(symbol))
        {
            errorMessage = "Enter a symbol first.";
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            var url = $"api/news/search?ticker={Uri.EscapeDataString(symbol.Trim())}&sourceFilter={Uri.EscapeDataString(sourceFilter)}&limit={limit}";
            var response = await Http.GetAsync(url);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to load news: {response.StatusCode}";
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true, PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
            var result = JsonSerializer.Deserialize<QuantResearchAgent.Models.PipelineSearchResult>(json, options);
            articles = result?.Articles ?? new List<QuantResearchAgent.Models.PipelineArticle>();
            selectedArticle = articles.FirstOrDefault();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectArticle(QuantResearchAgent.Models.PipelineArticle article)
    {
        selectedArticle = article;
    }

    private async Task ClearAsync()
    {
        if (string.IsNullOrWhiteSpace(symbol))
        {
            return;
        }

        try
        {
            var response = await Http.DeleteAsync($"api/news/cached/{Uri.EscapeDataString(symbol.Trim())}");
            if (response.IsSuccessStatusCode)
            {
                articles.Clear();
                selectedArticle = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}
