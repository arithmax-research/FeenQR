@inject IJSRuntime JS
@implements IDisposable

<div class="card">
    <div class="card-header">
        <h5 class="card-title">Technical Analysis</h5>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <label for="symbolInput" class="form-label">Symbol</label>
            <input type="text" class="form-control" id="symbolInput" @bind="symbol" @bind:event="oninput" @onkeyup="OnSymbolKeyUp" placeholder="e.g., BINANCE:BTCUSDT" />
        </div>
        <div class="mb-3">
            <label for="intervalSelect" class="form-label">Interval</label>
            <select class="form-select" id="intervalSelect" @onchange="OnIntervalChanged">
                <option value="1m">1 Minute</option>
                <option value="5m">5 Minutes</option>
                <option value="15m">15 Minutes</option>
                <option value="1h">1 Hour</option>
                <option value="4h">4 Hours</option>
                <option value="1D" selected>1 Day</option>
                <option value="1W">1 Week</option>
                <option value="1M">1 Month</option>
            </select>
        </div>
        
        <div class="mt-3" style="min-height: 500px;">
            <div id="technicalAnalysisWidget"></div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string InitialSymbol { get; set; } = "BINANCE:BTCUSDT";
    
    [Parameter]
    public string InitialInterval { get; set; } = "1D";

    private string symbol = "BINANCE:BTCUSDT";
    private string interval = "1D";
    private bool initialized = false;
    private System.Timers.Timer? debounceTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !initialized)
        {
            symbol = InitialSymbol;
            interval = InitialInterval;
            initialized = true;
            await UpdateWidget();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (initialized && (symbol != InitialSymbol || interval != InitialInterval))
        {
            symbol = InitialSymbol;
            interval = InitialInterval;
            await UpdateWidget();
        }
    }

    private void OnSymbolKeyUp(KeyboardEventArgs e)
    {
        // Debounce the symbol input
        if (debounceTimer != null)
        {
            debounceTimer.Stop();
            debounceTimer.Dispose();
        }

        debounceTimer = new System.Timers.Timer(500); // 500ms debounce
        debounceTimer.Elapsed += async (sender, args) =>
        {
            await InvokeAsync(async () =>
            {
                await UpdateWidget();
            });
            debounceTimer?.Dispose();
            debounceTimer = null;
        };
        debounceTimer.AutoReset = false;
        debounceTimer.Start();
    }

    private async Task OnIntervalChanged(ChangeEventArgs e)
    {
        interval = e.Value?.ToString() ?? "1D";
        await UpdateWidget();
    }

    private async Task UpdateWidget()
    {
        if (!string.IsNullOrWhiteSpace(symbol))
        {
            await JS.InvokeVoidAsync("createTechnicalAnalysisWidget", symbol, interval);
        }
    }

    public void Dispose()
    {
        if (debounceTimer != null)
        {
            debounceTimer.Stop();
            debounceTimer.Dispose();
        }
    }
}
