@using System.Text.Json

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="card-title mb-0">
            <i class="bi bi-newspaper"></i> News Scraper with AI Analytics
        </h5>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <label for="newsUrlInput" class="form-label fw-bold">News Article URL</label>
            <div class="input-group">
                <input type="text" 
                       class="form-control" 
                       id="newsUrlInput" 
                       @bind="newsUrl" 
                       @bind:event="oninput" 
                       placeholder="https://www.cnbc.com/..." />
                <button class="btn btn-primary" @onclick="ScrapeUrl" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Scraping...</span>
                    }
                    else
                    {
                        <i class="bi bi-cloud-download me-2"></i>
                        <span>Scrape & Analyze</span>
                    }
                </button>
            </div>
            <small class="form-text text-muted">
                Supported sources: CNBC, Bloomberg, Reuters, Yahoo Finance, MarketWatch, WSJ, FT
            </small>
        </div>

        <!-- Batch URLs Section -->
        <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <label class="form-label fw-bold mb-0">Batch URLs (Optional)</label>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleBatchMode">
                    <i class="bi bi-list-ul me-1"></i>
                    @(showBatchMode ? "Hide" : "Show") Batch Input
                </button>
            </div>
            
            @if (showBatchMode)
            {
                <textarea class="form-control mb-2" 
                          rows="4" 
                          @bind="batchUrls" 
                          placeholder="Enter multiple URLs (one per line)&#10;https://www.cnbc.com/article1&#10;https://www.bloomberg.com/article2&#10;https://www.reuters.com/article3"></textarea>
                <button class="btn btn-secondary btn-sm" @onclick="ScrapeBatchUrls" disabled="@isLoading">
                    <i class="bi bi-cloud-download me-1"></i> Scrape All
                </button>
            }
        </div>

        <!-- Results Section -->
        @if (errorMessage != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }

        @if (scrapedResults != null && scrapedResults.Any())
        {
            <div class="mt-4">
                <h6 class="mb-3">
                    <i class="bi bi-file-text me-2"></i>
                    Scraped Articles (@scrapedResults.Count)
                </h6>
                
                @foreach (var result in scrapedResults)
                {
                    <div class="card mb-3 border @(result.Success ? "border-success" : "border-danger")">
                        @if (result.Success && result.Article != null)
                        {
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <strong>@result.Article.Source</strong>
                                <button class="btn btn-sm btn-outline-primary" 
                                        @onclick="() => ToggleArticle(result)">
                                    <i class="bi bi-chevron-@(expandedArticles.Contains(result) ? "up" : "down")"></i>
                                </button>
                            </div>
                            <div class="card-body">
                                <h6 class="card-title">@result.Article.Title</h6>
                                
                                @if (!string.IsNullOrEmpty(result.Article.Author))
                                {
                                    <p class="text-muted small mb-2">
                                        <i class="bi bi-person me-1"></i> @result.Article.Author
                                        @if (!string.IsNullOrEmpty(result.Article.PublishedDate))
                                        {
                                            <span class="ms-2">
                                                <i class="bi bi-calendar me-1"></i> @result.Article.PublishedDate
                                            </span>
                                        }
                                    </p>
                                }
                                
                                <a href="@result.Article.Url" target="_blank" class="btn btn-sm btn-link px-0">
                                    <i class="bi bi-box-arrow-up-right me-1"></i> View Original Article
                                </a>

                                @if (expandedArticles.Contains(result))
                                {
                                    <!-- Article Content -->
                                    <div class="mt-3 border-top pt-3">
                                        <h6><i class="bi bi-file-text me-2"></i> Article Content</h6>
                                        <div class="article-content" style="max-height: 300px; overflow-y: auto; font-size: 0.9rem;">
                                            @foreach (var paragraph in result.Article.Content.Split("\n\n"))
                                            {
                                                <p>@paragraph</p>
                                            }
                                        </div>
                                    </div>

                                    <!-- AI Analytics -->
                                    @if (result.Analytics != null)
                                    {
                                        <div class="mt-4 border-top pt-3">
                                            <h6 class="text-primary">
                                                <i class="bi bi-robot me-2"></i> DeepSeek AI Analytics
                                            </h6>
                                            
                                            <!-- Summary -->
                                            @if (!string.IsNullOrEmpty(result.Analytics.Summary))
                                            {
                                                <div class="mb-3">
                                                    <strong class="d-block mb-1">Summary:</strong>
                                                    <p class="alert alert-info">@result.Analytics.Summary</p>
                                                </div>
                                            }

                                            <!-- Key Topics -->
                                            @if (result.Analytics.KeyTopics != null && result.Analytics.KeyTopics.Any())
                                            {
                                                <div class="mb-3">
                                                    <strong class="d-block mb-2">Key Topics:</strong>
                                                    <div class="d-flex flex-wrap gap-2">
                                                        @foreach (var topic in result.Analytics.KeyTopics)
                                                        {
                                                            <span class="badge bg-secondary">@topic</span>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            <!-- Sentiment -->
                                            @if (!string.IsNullOrEmpty(result.Analytics.Sentiment))
                                            {
                                                <div class="mb-3">
                                                    <strong class="d-block mb-1">Sentiment Analysis:</strong>
                                                    <p class="alert alert-@GetSentimentClass(result.Analytics.Sentiment) mb-0">
                                                        @result.Analytics.Sentiment
                                                    </p>
                                                </div>
                                            }

                                            <!-- Market Impact -->
                                            @if (!string.IsNullOrEmpty(result.Analytics.MarketImpact))
                                            {
                                                <div class="mb-3">
                                                    <strong class="d-block mb-1">Market Impact:</strong>
                                                    <p>@result.Analytics.MarketImpact</p>
                                                </div>
                                            }

                                            <!-- Key Entities -->
                                            @if (result.Analytics.KeyEntities != null && result.Analytics.KeyEntities.Any())
                                            {
                                                <div class="mb-3">
                                                    <strong class="d-block mb-2">Key Entities:</strong>
                                                    <ul class="list-unstyled">
                                                        @foreach (var entity in result.Analytics.KeyEntities)
                                                        {
                                                            <li><i class="bi bi-chevron-right me-1"></i> @entity</li>
                                                        }
                                                    </ul>
                                                </div>
                                            }

                                            <!-- Actionable Insights -->
                                            @if (result.Analytics.ActionableInsights != null && result.Analytics.ActionableInsights.Any())
                                            {
                                                <div class="mb-3">
                                                    <strong class="d-block mb-2">Actionable Insights:</strong>
                                                    <ul>
                                                        @foreach (var insight in result.Analytics.ActionableInsights)
                                                        {
                                                            <li>@insight</li>
                                                        }
                                                    </ul>
                                                </div>
                                            }

                                            <!-- Related Sectors -->
                                            @if (result.Analytics.RelatedSectors != null && result.Analytics.RelatedSectors.Any())
                                            {
                                                <div class="mb-3">
                                                    <strong class="d-block mb-2">Related Sectors:</strong>
                                                    <div class="d-flex flex-wrap gap-2">
                                                        @foreach (var sector in result.Analytics.RelatedSectors)
                                                        {
                                                            <span class="badge bg-primary">@sector</span>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            <!-- Full Analysis -->
                                            <details class="mt-3">
                                                <summary class="btn btn-sm btn-outline-secondary">
                                                    <i class="bi bi-eye me-1"></i> View Full Analysis
                                                </summary>
                                                <div class="mt-2 p-3 bg-light rounded">
                                                    <pre style="white-space: pre-wrap; font-size: 0.85rem;">@result.Analytics.FullAnalysis</pre>
                                                </div>
                                            </details>
                                        </div>
                                    }
                                }
                            </div>
                        }
                        else
                        {
                            <div class="card-body">
                                <div class="alert alert-danger mb-0">
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    @result.Error
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (isLoading)
        {
            <div class="mt-3 text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted">Scraping article and generating AI analytics...</p>
            </div>
        }
    </div>
</div>

@code {
    private string newsUrl = "";
    private string batchUrls = "";
    private bool showBatchMode = false;
    private bool isLoading = false;
    private string? errorMessage;
    private List<NewsScraperResult>? scrapedResults;
    private HashSet<NewsScraperResult> expandedArticles = new();

    [Inject]
    private HttpClient Http { get; set; } = default!;

    private async Task ScrapeUrl()
    {
        if (string.IsNullOrWhiteSpace(newsUrl))
        {
            errorMessage = "Please enter a valid URL";
            return;
        }

        isLoading = true;
        errorMessage = null;
        scrapedResults = null;

        try
        {
            var requestData = new { Url = newsUrl };
            var response = await Http.PostAsJsonAsync("api/scrape-news-url", requestData);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<NewsScraperResult>();
                if (result != null)
                {
                    scrapedResults = new List<NewsScraperResult> { result };
                    if (result.Success)
                    {
                        expandedArticles.Add(result);
                    }
                    else
                    {
                        errorMessage = result.Error;
                    }
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to scrape URL: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }

        isLoading = false;
    }

    private async Task ScrapeBatchUrls()
    {
        if (string.IsNullOrWhiteSpace(batchUrls))
        {
            errorMessage = "Please enter at least one URL";
            return;
        }

        isLoading = true;
        errorMessage = null;
        scrapedResults = null;

        try
        {
            var urls = batchUrls.Split('\n', StringSplitOptions.RemoveEmptyEntries)
                                 .Select(u => u.Trim())
                                 .Where(u => !string.IsNullOrWhiteSpace(u))
                                 .ToList();

            if (!urls.Any())
            {
                errorMessage = "No valid URLs found";
                isLoading = false;
                return;
            }

            var requestData = new { Urls = urls };
            var response = await Http.PostAsJsonAsync("api/scrape-news-urls-batch", requestData);
            
            if (response.IsSuccessStatusCode)
            {
                var responseData = await response.Content.ReadFromJsonAsync<BatchResponse>();
                if (responseData?.Results != null)
                {
                    scrapedResults = responseData.Results;
                    // Auto-expand first successful result
                    var firstSuccess = scrapedResults.FirstOrDefault(r => r.Success);
                    if (firstSuccess != null)
                    {
                        expandedArticles.Add(firstSuccess);
                    }
                }
            }
            else
            {
                errorMessage = $"Failed to scrape URLs: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }

        isLoading = false;
    }

    private void ToggleBatchMode()
    {
        showBatchMode = !showBatchMode;
    }

    private void ToggleArticle(NewsScraperResult result)
    {
        if (expandedArticles.Contains(result))
        {
            expandedArticles.Remove(result);
        }
        else
        {
            expandedArticles.Add(result);
        }
    }

    private string GetSentimentClass(string sentiment)
    {
        if (sentiment.Contains("positive", StringComparison.OrdinalIgnoreCase))
            return "success";
        if (sentiment.Contains("negative", StringComparison.OrdinalIgnoreCase))
            return "danger";
        return "secondary";
    }

    // Data models matching the backend
    public class NewsScraperResult
    {
        public bool Success { get; set; }
        public string Error { get; set; } = string.Empty;
        public ScrapedNewsArticle? Article { get; set; }
        public NewsAnalytics? Analytics { get; set; }
    }

    public class ScrapedNewsArticle
    {
        public string Title { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
        public string Source { get; set; } = string.Empty;
        public string Author { get; set; } = string.Empty;
        public string PublishedDate { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
    }

    public class NewsAnalytics
    {
        public string Summary { get; set; } = string.Empty;
        public List<string> KeyTopics { get; set; } = new();
        public string Sentiment { get; set; } = string.Empty;
        public string MarketImpact { get; set; } = string.Empty;
        public List<string> KeyEntities { get; set; } = new();
        public List<string> ActionableInsights { get; set; } = new();
        public List<string> RelatedSectors { get; set; } = new();
        public string FullAnalysis { get; set; } = string.Empty;
        public DateTime AnalyzedAt { get; set; }
    }

    public class BatchResponse
    {
        public List<NewsScraperResult> Results { get; set; } = new();
        public int Total { get; set; }
        public int Successful { get; set; }
    }
}
