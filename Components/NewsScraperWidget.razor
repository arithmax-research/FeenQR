@using System.Text.Json

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="card-title mb-0">
            <i class="bi bi-newspaper me-2"></i>News Scraper with AI Analytics
        </h5>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end mb-3">
            <div class="col-lg-3 col-md-4">
                <label class="form-label fw-semibold">Symbol</label>
                <input class="form-control" @bind="symbol" @bind:event="oninput" placeholder="TSLA" @onkeypress="HandleKeyPress" />
            </div>
            <div class="col-lg-3 col-md-4">
                <label class="form-label fw-semibold">Source</label>
                <select class="form-select" @bind="sourceFilter">
                    <option value="All">All Sources</option>
                    <option value="Reuters">Reuters</option>
                    <option value="Bloomberg">Bloomberg</option>
                    <option value="CNBC">CNBC</option>
                    <option value="MarketWatch">MarketWatch</option>
                    <option value="Yahoo">Yahoo</option>
                </select>
            </div>
            <div class="col-lg-2 col-md-4">
                <label class="form-label fw-semibold">Limit</label>
                <input class="form-control" type="number" min="1" max="50" @bind="limit" />
            </div>
            <div class="col-lg-2 col-md-6 d-grid">
                <button class="btn btn-primary" @onclick="LoadArticlesAsync" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Loading</span>
                    }
                    else
                    {
                        <span><i class="bi bi-search me-2"></i>Load</span>
                    }
                </button>
            </div>
            <div class="col-lg-2 col-md-6 d-grid">
                <button class="btn btn-outline-secondary" @onclick="ClearAsync" disabled="@(string.IsNullOrWhiteSpace(symbol))">
                    <i class="bi bi-trash me-2"></i>Clear Cache
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
            </div>
        }

        @if (articles.Count > 0)
        {
            <div class="row g-3">
                <div class="col-lg-5">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="fw-semibold"><i class="bi bi-list-ul me-2"></i>Articles (@articles.Count)</span>
                            <small class="text-muted">Click one to populate the source pane</small>
                        </div>
                        <div class="list-group list-group-flush" style="max-height: 620px; overflow:auto;">
                            @foreach (var article in articles)
                            {
                                <button class="list-group-item list-group-item-action @(selectedArticle?.Url == article.Url ? "active" : "")" @onclick="() => SelectArticle(article)">
                                    <div class="text-start">
                                        <div class="fw-semibold">@article.Title</div>
                                        <div class="small @(selectedArticle?.Url == article.Url ? "text-white-50" : "text-muted")">@article.Provider · @article.PublishedDate.ToString("g")</div>
                                    </div>
                                </button>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="fw-semibold"><i class="bi bi-file-earmark-text me-2"></i>Full Article / AI Analytics</span>
                            @if (selectedArticle != null)
                            {
                                <a class="btn btn-sm btn-outline-primary" href="@selectedArticle.Url" target="_blank"><i class="bi bi-box-arrow-up-right me-1"></i>Open</a>
                            }
                        </div>
                        <div class="card-body" style="max-height: 620px; overflow:auto;">
                            @if (selectedArticle == null)
                            {
                                <div class="text-center text-muted py-5">
                                    <i class="bi bi-arrow-left-circle display-6"></i>
                                    <div class="mt-3">Select a news item to inspect the full source and analytics.</div>
                                </div>
                            }
                            else
                            {
                                <h5 class="mb-2">@selectedArticle.Title</h5>
                                <div class="small text-muted mb-3">@selectedArticle.Provider · @selectedArticle.PublishedDate.ToString("f")</div>
                                @if (!string.IsNullOrWhiteSpace(selectedArticle.Summary))
                                {
                                    <div class="alert alert-info py-2 px-3">@selectedArticle.Summary</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(selectedArticle.FullContent))
                                {
                                    <div class="pipeline-content">@selectedArticle.FullContent</div>
                                }
                                else
                                {
                                    <div class="alert alert-warning">No full content was returned for this item.</div>
                                }

                                <div class="mt-3 d-flex gap-2 flex-wrap">
                                    <button class="btn btn-success btn-sm" @onclick="AnalyzeSymbolAsync" disabled="@isLoadingAnalysis">
                                        @if (isLoadingAnalysis)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                            <span>Analyzing</span>
                                        }
                                        else
                                        {
                                            <span><i class="bi bi-graph-up me-1"></i>Symbol Sentiment</span>
                                        }
                                    </button>
                                    <button class="btn btn-outline-dark btn-sm" @onclick="AnalyzeSelectedAsync" disabled="@isLoadingAnalysis">
                                        <i class="bi bi-stars me-1"></i>AI Notes
                                    </button>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(selectedAnalysis))
                                {
                                    <div class="alert alert-dark mt-3 mb-0">
                                        <div class="fw-semibold mb-2">Analytics</div>
                                        <pre class="mb-0" style="white-space: pre-wrap; font-family: inherit;">@selectedAnalysis</pre>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (!isLoading)
        {
            <div class="alert alert-info mb-0">
                <i class="bi bi-info-circle me-2"></i>Search a symbol to load pipeline articles, then click a row to show the full source and analytics.
            </div>
        }
    </div>
</div>

@code {
    private string symbol = "TSLA";
    private string sourceFilter = "All";
    private int limit = 20;
    private bool isLoading;
    private bool isLoadingAnalysis;
    private string? errorMessage;
    private string? selectedAnalysis;
    private List<QuantResearchAgent.Models.PipelineArticle> articles = new();
    private QuantResearchAgent.Models.PipelineArticle? selectedArticle;

    [Inject]
    private HttpClient Http { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadArticlesAsync();
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadArticlesAsync();
        }
    }

    private async Task LoadArticlesAsync()
    {
        if (string.IsNullOrWhiteSpace(symbol))
        {
            errorMessage = "Please enter a symbol.";
            return;
        }

        isLoading = true;
        errorMessage = null;
        selectedAnalysis = null;

        try
        {
            var response = await Http.GetAsync($"api/news/search?ticker={Uri.EscapeDataString(symbol.Trim())}&sourceFilter={Uri.EscapeDataString(sourceFilter)}&limit={limit}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to fetch articles: {response.StatusCode}";
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true, PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
            var result = JsonSerializer.Deserialize<QuantResearchAgent.Models.PipelineSearchResult>(json, options);
            articles = result?.Articles ?? new List<QuantResearchAgent.Models.PipelineArticle>();
            selectedArticle = articles.FirstOrDefault();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectArticle(QuantResearchAgent.Models.PipelineArticle article)
    {
        selectedArticle = article;
        selectedAnalysis = null;
    }

    private async Task AnalyzeSymbolAsync()
    {
        if (string.IsNullOrWhiteSpace(symbol))
        {
            return;
        }

        isLoadingAnalysis = true;
        selectedAnalysis = null;

        try
        {
            var response = await Http.GetAsync($"api/sentiment/symbol/{Uri.EscapeDataString(symbol.Trim())}?newsLimit={limit}");
            if (!response.IsSuccessStatusCode)
            {
                selectedAnalysis = $"Sentiment request failed: {response.StatusCode}";
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            using var doc = JsonDocument.Parse(json);
            selectedAnalysis = JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions { WriteIndented = true });
        }
        catch (Exception ex)
        {
            selectedAnalysis = ex.Message;
        }
        finally
        {
            isLoadingAnalysis = false;
        }
    }

    private async Task AnalyzeSelectedAsync()
    {
        if (selectedArticle == null)
        {
            return;
        }

        isLoadingAnalysis = true;
        selectedAnalysis = null;

        try
        {
            var preview = selectedArticle.FullContent;
            if (string.IsNullOrWhiteSpace(preview))
            {
                preview = selectedArticle.Summary;
            }

            if (string.IsNullOrWhiteSpace(preview))
            {
                selectedAnalysis = "No content available for analysis.";
                return;
            }

            selectedAnalysis = preview.Length > 700 ? preview.Substring(0, 700) + "..." : preview;
        }
        catch (Exception ex)
        {
            selectedAnalysis = ex.Message;
        }
        finally
        {
            isLoadingAnalysis = false;
        }
    }

    private async Task ClearAsync()
    {
        try
        {
            await Http.DeleteAsync($"api/news/cached/{Uri.EscapeDataString(symbol.Trim())}");
            articles.Clear();
            selectedArticle = null;
            selectedAnalysis = null;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}
