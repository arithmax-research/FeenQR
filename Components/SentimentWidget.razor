@using System.Text.Json
@using System.Text.Json.Serialization

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="card-title mb-0">
            <i class="bi bi-graph-up-arrow"></i> News Sentiment Analysis
        </h5>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <label for="sentimentSymbolInput" class="form-label fw-bold">Stock Symbol</label>
            <div class="input-group">
                <input type="text" 
                       class="form-control" 
                       id="sentimentSymbolInput" 
                       @bind="symbol" 
                       @bind:event="oninput" 
                       placeholder="Enter symbol (e.g., AAPL, TSLA, BA)"
                       @onkeypress="HandleKeyPress" />
                <button class="btn btn-primary" @onclick="LoadSentiment" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Analyzing...</span>
                    }
                    else
                    {
                        <i class="bi bi-search me-2"></i>
                        <span>Analyze Sentiment</span>
                    }
                </button>
            </div>
            <small class="form-text text-muted">
                Analyzes news from 6 sources: NewsAPI, Google, Yahoo Finance, Finviz, Reddit, MarketWatch
            </small>
        </div>

        @if (errorMessage != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        
        @if (sentimentAnalysis != null)
        {
            <div class="mt-4">
                <!-- Overall Sentiment Card -->
                <div class="card mb-3 border-@GetSentimentColorClass(sentimentAnalysis.OverallSentiment)">
                    <div class="card-header bg-@GetSentimentColorClass(sentimentAnalysis.OverallSentiment) text-white">
                        <h6 class="mb-0">
                            <i class="bi bi-bar-chart-fill me-2"></i>
                            @symbol.ToUpper() Overall Sentiment
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3 text-center border-end">
                                <div class="sentiment-score">
                                    <div class="display-4 fw-bold text-@GetSentimentColorClass(sentimentAnalysis.OverallSentiment)">
                                        @sentimentAnalysis.SentimentScore.ToString("F2")
                                    </div>
                                    <small class="text-muted">Score</small>
                                </div>
                            </div>
                            <div class="col-md-3 text-center border-end">
                                <div class="sentiment-label">
                                    <div class="h4 fw-bold">@sentimentAnalysis.OverallSentiment</div>
                                    <small class="text-muted">Sentiment</small>
                                </div>
                            </div>
                            <div class="col-md-3 text-center border-end">
                                <div class="confidence">
                                    <div class="h4 fw-bold">@((sentimentAnalysis.Confidence * 100).ToString("F0"))%</div>
                                    <small class="text-muted">Confidence</small>
                                </div>
                            </div>
                            <div class="col-md-3 text-center">
                                <div class="news-count">
                                    <div class="h4 fw-bold">@sentimentAnalysis.NewsCount</div>
                                    <small class="text-muted">News Count</small>
                                </div>
                            </div>
                        </div>

                        <!-- Sentiment Breakdown -->
                        <div class="mt-3">
                            <strong class="d-block mb-2">Sentiment Distribution:</strong>
                            <div class="progress" style="height: 25px;">
                                @{
                                    var positivePercent = sentimentAnalysis.PositivePercent;
                                    var negativePercent = sentimentAnalysis.NegativePercent;
                                    var neutralPercent = 100 - positivePercent - negativePercent;
                                }
                                @if (positivePercent > 0)
                                {
                                    <div class="progress-bar bg-success" role="progressbar" 
                                         style="width: @(positivePercent)%" 
                                         aria-valuenow="@positivePercent" aria-valuemin="0" aria-valuemax="100">
                                        @positivePercent.ToString("F0")%
                                    </div>
                                }
                                @if (neutralPercent > 0)
                                {
                                    <div class="progress-bar bg-secondary" role="progressbar" 
                                         style="width: @(neutralPercent)%" 
                                         aria-valuenow="@neutralPercent" aria-valuemin="0" aria-valuemax="100">
                                        @neutralPercent.ToString("F0")%
                                    </div>
                                }
                                @if (negativePercent > 0)
                                {
                                    <div class="progress-bar bg-danger" role="progressbar" 
                                         style="width: @(negativePercent)%" 
                                         aria-valuenow="@negativePercent" aria-valuemin="0" aria-valuemax="100">
                                        @negativePercent.ToString("F0")%
                                    </div>
                                }
                            </div>
                            <div class="d-flex justify-content-between mt-2">
                                <small><span class="badge bg-success">Positive: @positivePercent.ToString("F0")%</span></small>
                                <small><span class="badge bg-secondary">Neutral: @neutralPercent.ToString("F0")%</span></small>
                                <small><span class="badge bg-danger">Negative: @negativePercent.ToString("F0")%</span></small>
                            </div>
                        </div>

                        <!-- Sources Analyzed -->
                        @if (sentimentAnalysis.Sources != null && sentimentAnalysis.Sources.Any())
                        {
                            <div class="mt-3">
                                <strong class="d-block mb-2">Sources Analyzed:</strong>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var source in sentimentAnalysis.Sources)
                                    {
                                        <span class="badge bg-info">@source</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- AI Insights -->
                @if (!string.IsNullOrEmpty(sentimentAnalysis.Summary))
                {
                    <div class="card mb-3">
                        <div class="card-header bg-info text-white">
                            <h6 class="mb-0">
                                <i class="bi bi-robot me-2"></i> AI Insights
                            </h6>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@sentimentAnalysis.Summary</p>
                        </div>
                    </div>
                }

                <!-- Recent News -->
                @if (sentimentAnalysis.RecentNews != null && sentimentAnalysis.RecentNews.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="mb-0">
                                    <i class="bi bi-newspaper me-2"></i> Recent News (@sentimentAnalysis.RecentNews.Length articles)
                                </h6>
                                <button class="btn btn-sm btn-outline-primary" @onclick="ExportToCSV">
                                    <i class="bi bi-download me-1"></i> Export All Screener Data (CSV)
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            @foreach (var news in sentimentAnalysis.RecentNews)
                            {
                                <div class="card mb-3 border-start border-@GetSentimentColorClass(news.SentimentLabel) border-3">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div class="flex-grow-1">
                                                <h6 class="card-title mb-1">
                                                    <a href="@news.Link" target="_blank" class="text-decoration-none text-dark">
                                                        @news.Title
                                                        <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                                    </a>
                                                </h6>
                                                <div class="d-flex gap-2 mb-2">
                                                    <span class="badge bg-secondary">@news.Source</span>
                                                    <small class="text-muted">
                                                        <i class="bi bi-calendar me-1"></i>
                                                        @news.PublishedDate.ToString("MMM dd, yyyy HH:mm")
                                                    </small>
                                                </div>
                                            </div>
                                            <div class="text-end ms-3">
                                                <span class="badge bg-@GetSentimentColorClass(news.SentimentLabel) mb-1">
                                                    @news.SentimentLabel
                                                </span>
                                                <div class="small text-muted">
                                                    Score: @news.SentimentScore.ToString("F2")
                                                </div>
                                            </div>
                                        </div>
                                        
                                        @if (!string.IsNullOrEmpty(news.Summary))
                                        {
                                            <p class="card-text text-muted small mb-2">
                                                @news.Summary
                                            </p>
                                        }
                                        
                                        @if (news.KeyTopics != null && news.KeyTopics.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                <small class="text-muted me-1">Topics:</small>
                                                @foreach (var topic in news.KeyTopics)
                                                {
                                                    <span class="badge bg-light text-dark">@topic</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .sentiment-score, .sentiment-label, .confidence, .news-count {
        padding: 10px 0;
    }
    
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.1);
    }
</style>

@code {
    private string symbol = "BA";
    private SentimentAnalysisResult? sentimentAnalysis;
    private string? errorMessage;
    private bool isLoading = false;

    private async Task LoadSentiment()
    {
        if (string.IsNullOrWhiteSpace(symbol))
        {
            errorMessage = "Please enter a stock symbol";
            return;
        }

        isLoading = true;
        errorMessage = null;
        sentimentAnalysis = null;
        
        try
        {
            var response = await Http.GetAsync($"api/sentiment/symbol/{symbol.Trim().ToUpper()}?newsLimit=20");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions 
                { 
                    PropertyNameCaseInsensitive = true,
                    PropertyNamingPolicy = JsonNamingPolicy.CamelCase
                };
                sentimentAnalysis = JsonSerializer.Deserialize<SentimentAnalysisResult>(json, options);
            }
            else
            {
                errorMessage = $"Failed to load sentiment data: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadSentiment();
        }
    }

    private string GetSentimentColorClass(string sentiment)
    {
        return sentiment?.ToLower() switch
        {
            "very positive" => "success",
            "positive" => "success",
            "very negative" => "danger",
            "negative" => "danger",
            _ => "secondary"
        };
    }

    private void ExportToCSV()
    {
        if (sentimentAnalysis?.RecentNews == null) return;
        
        var csv = "Source,Published,Sentiment,Title,Link\n";
        foreach (var news in sentimentAnalysis.RecentNews)
        {
            csv += $"\"{news.Source}\",\"{news.PublishedDate:yyyy-MM-dd HH:mm}\",\"{news.SentimentLabel}\",\"{news.Title.Replace("\"", "\"\"")}\",\"{news.Link}\"\n";
        }
        
        // Trigger download (simplified - in production use JSInterop)
        Console.WriteLine(csv);
    }

    [Inject]
    private HttpClient Http { get; set; } = default!;

    // Data models
    public class SentimentAnalysisResult
    {
        public string Symbol { get; set; } = "";
        public string OverallSentiment { get; set; } = "";
        public double SentimentScore { get; set; }
        public double Confidence { get; set; }
        public int NewsCount { get; set; }
        public double PositivePercent { get; set; }
        public double NegativePercent { get; set; }
        public string[] Sources { get; set; } = Array.Empty<string>();
        public string Summary { get; set; } = "";
        public NewsItemDto[] RecentNews { get; set; } = Array.Empty<NewsItemDto>();
    }

    public class NewsItemDto
    {
        public string Title { get; set; } = "";
        public string Source { get; set; } = "";
        public DateTime PublishedDate { get; set; }
        public string SentimentLabel { get; set; } = "";
        public double SentimentScore { get; set; }
        public string Link { get; set; } = "";
        public string Summary { get; set; } = "";
        public string[] KeyTopics { get; set; } = Array.Empty<string>();
    }
}