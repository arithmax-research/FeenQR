@using System.Text.Json

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="card-title mb-0">
            <i class="bi bi-graph-up-arrow me-2"></i>Symbol Sentiment via Pipeline
        </h5>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end mb-3">
            <div class="col-lg-4 col-md-6">
                <label class="form-label fw-semibold">Symbol</label>
                <input class="form-control" @bind="symbol" @bind:event="oninput" placeholder="TSLA" @onkeypress="HandleKeyPress" />
            </div>
            <div class="col-lg-2 col-md-3">
                <label class="form-label fw-semibold">News Limit</label>
                <input class="form-control" type="number" min="1" max="50" @bind="newsLimit" />
            </div>
            <div class="col-lg-3 col-md-3 d-grid">
                <button class="btn btn-primary" @onclick="LoadSentimentAsync" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Analyzing</span>
                    }
                    else
                    {
                        <span><i class="bi bi-search me-2"></i>Analyze</span>
                    }
                </button>
            </div>
            <div class="col-lg-3 d-grid">
                <button class="btn btn-outline-secondary" @onclick="ClearAsync" disabled="@(string.IsNullOrWhiteSpace(symbol))">
                    <i class="bi bi-trash me-2"></i>Clear Cache
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
            </div>
        }

        @if (analysis != null)
        {
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <div class="metric-card">
                        <div class="metric-label">Sentiment</div>
                        <div class="metric-value text-@GetSentimentClass(analysis.OverallSentiment)">@analysis.OverallSentiment</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="metric-card">
                        <div class="metric-label">Score</div>
                        <div class="metric-value">@analysis.SentimentScore.ToString("F2")</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="metric-card">
                        <div class="metric-label">Confidence</div>
                        <div class="metric-value">@((analysis.Confidence * 100).ToString("F0"))%</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="metric-card">
                        <div class="metric-label">Articles</div>
                        <div class="metric-value">@analysis.NewsCount</div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light fw-semibold">
                            <i class="bi bi-tags me-2"></i>Key Themes
                        </div>
                        <div class="card-body">
                            @if (analysis.KeyThemes?.Any() == true)
                            {
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    @foreach (var theme in analysis.KeyThemes)
                                    {
                                        <span class="badge rounded-pill bg-dark">@theme</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">No themes returned yet.</p>
                            }

                            <div class="mt-3">
                                <div class="fw-semibold mb-2">Recent News</div>
                                <div style="max-height: 360px; overflow:auto;">
                                    @foreach (var item in analysis.RecentNews ?? new List<RecentNewsItem>())
                                    {
                                        <button class="list-group-item list-group-item-action w-100 text-start mb-2 @(selectedLink == item.Link ? "active" : "")" @onclick="() => SelectNews(item)">
                                            <div class="fw-semibold">@item.Title</div>
                                            <div class="small @(selectedLink == item.Link ? "text-white-50" : "text-muted")">@item.Source · @item.PublishedDate.ToString("g")</div>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="fw-semibold"><i class="bi bi-file-text me-2"></i>Selected News Item</span>
                            @if (!string.IsNullOrWhiteSpace(selectedLink))
                            {
                                <a class="btn btn-sm btn-outline-primary" href="@selectedLink" target="_blank"><i class="bi bi-box-arrow-up-right me-1"></i>Open</a>
                            }
                        </div>
                        <div class="card-body" style="max-height: 620px; overflow:auto;">
                            @if (selectedNews == null)
                            {
                                <div class="text-center text-muted py-5">
                                    <i class="bi bi-arrow-left-circle display-6"></i>
                                    <div class="mt-3">Pick a news item to inspect the full source and AI summary.</div>
                                </div>
                            }
                            else
                            {
                                <h5>@selectedNews.Title</h5>
                                <div class="small text-muted mb-3">@selectedNews.Source · @selectedNews.PublishedDate.ToString("f")</div>
                                @if (!string.IsNullOrWhiteSpace(selectedNews.Summary))
                                {
                                    <div class="alert alert-info py-2 px-3">@selectedNews.Summary</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(selectedNews.FullContent))
                                {
                                    <div class="pipeline-content">@selectedNews.FullContent</div>
                                }
                                else
                                {
                                    <div class="alert alert-warning">No full content was returned for this item.</div>
                                }

                                <div class="mt-3">
                                    <button class="btn btn-success btn-sm" @onclick="AnalyzeSelectedAsync" disabled="@isLoadingSelected">
                                        @if (isLoadingSelected)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                            <span>Analyzing</span>
                                        }
                                        else
                                        {
                                            <span><i class="bi bi-robot me-1"></i>AI Summary</span>
                                        }
                                    </button>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(selectedAnalysis))
                                {
                                    <div class="alert alert-dark mt-3 mb-0">
                                        <div class="fw-semibold mb-2">AI Notes</div>
                                        @selectedAnalysis
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (!isLoading)
        {
            <div class="alert alert-info mb-0">
                <i class="bi bi-info-circle me-2"></i>Enter a symbol to fetch pipeline-backed sentiment and article context.
            </div>
        }
    </div>
</div>

@code {
    private string symbol = "TSLA";
    private int newsLimit = 10;
    private bool isLoading;
    private bool isLoadingSelected;
    private string? errorMessage;
    private string? selectedAnalysis;
    private string? selectedLink;
    private SentimentResponse? analysis;
    private RecentNewsItem? selectedNews;

    [Inject]
    private HttpClient Http { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadSentimentAsync();
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadSentimentAsync();
        }
    }

    private async Task LoadSentimentAsync()
    {
        if (string.IsNullOrWhiteSpace(symbol))
        {
            errorMessage = "Please enter a symbol.";
            return;
        }

        isLoading = true;
        errorMessage = null;
        selectedAnalysis = null;

        try
        {
            var response = await Http.GetAsync($"api/sentiment/symbol/{Uri.EscapeDataString(symbol.Trim())}?newsLimit={newsLimit}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to load sentiment: {response.StatusCode}";
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true, PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
            analysis = JsonSerializer.Deserialize<SentimentResponse>(json, options);
            selectedNews = analysis?.RecentNews?.FirstOrDefault();
            selectedLink = selectedNews?.Link;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectNews(RecentNewsItem item)
    {
        selectedNews = item;
        selectedLink = item.Link;
        selectedAnalysis = null;
    }

    private async Task AnalyzeSelectedAsync()
    {
        if (selectedNews == null)
        {
            return;
        }

        isLoadingSelected = true;
        selectedAnalysis = null;

        try
        {
            var content = selectedNews.FullContent;
            if (string.IsNullOrWhiteSpace(content))
            {
                content = selectedNews.Summary ?? string.Empty;
            }

            var preview = content.Length > 400 ? content.Substring(0, 400) + "..." : content;
            selectedAnalysis = string.IsNullOrWhiteSpace(preview)
                ? "No article text available to analyze."
                : $"Article preview:
{preview}

Use the full sentiment endpoint for deeper symbol-level analysis.";
        }
        catch (Exception ex)
        {
            selectedAnalysis = ex.Message;
        }
        finally
        {
            isLoadingSelected = false;
        }
    }

    private async Task ClearAsync()
    {
        try
        {
            await Http.DeleteAsync($"api/news/cached/{Uri.EscapeDataString(symbol.Trim())}");
            analysis = null;
            selectedNews = null;
            selectedLink = null;
            selectedAnalysis = null;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private string GetSentimentClass(string? sentiment) => sentiment?.ToLower() switch
    {
        "positive" or "bullish" => "success",
        "negative" or "bearish" => "danger",
        "neutral" => "secondary",
        _ => "primary"
    };

    private sealed class SentimentResponse
    {
        public string? OverallSentiment { get; set; }
        public double SentimentScore { get; set; }
        public double Confidence { get; set; }
        public int NewsCount { get; set; }
        public List<string>? KeyThemes { get; set; }
        public List<RecentNewsItem>? RecentNews { get; set; }
    }

    private sealed class RecentNewsItem
    {
        public string? Title { get; set; }
        public string? Source { get; set; }
        public DateTime PublishedDate { get; set; }
        public string? Link { get; set; }
        public string? Summary { get; set; }
        public string? FullContent { get; set; }
    }
}
